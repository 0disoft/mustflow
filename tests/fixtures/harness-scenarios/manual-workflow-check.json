{
  "schema_version": "1",
  "name": "manual-workflow-check",
  "files": ["AGENTS.md"],
  "command_contract": {
    "intents": {
      "mustflow_check": {
        "status": "manual_only",
        "description": "Validate workflow files.",
        "reason": "Workflow checks are manual in this fixture.",
        "required_after": ["mustflow_config_change", "mustflow_docs_change"]
      }
    }
  },
  "expect": {
    "validation_reasons": ["mustflow_config_change", "mustflow_docs_change"],
    "runnable_intents": [],
    "gap_reasons": ["mustflow_config_change", "mustflow_docs_change"],
    "candidate_statuses": [
      {
        "reason": "mustflow_config_change",
        "intent": "mustflow_check",
        "status": "skipped",
        "skip_reason": "status_not_configured"
      },
      {
        "reason": "mustflow_docs_change",
        "intent": "mustflow_check",
        "status": "skipped",
        "skip_reason": "status_not_configured"
      }
    ]
  }
}
