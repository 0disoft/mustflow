{
  "schema_version": "1",
  "name": "template-drift",
  "files": ["templates/default/manifest.toml"],
  "command_contract": {
    "intents": {
      "test_release": {
        "status": "configured",
        "lifecycle": "oneshot",
        "run_policy": "agent_allowed",
        "description": "Run release-sensitive package metadata and packaging tests.",
        "argv": ["node", "scripts/check-release.mjs"],
        "cwd": ".",
        "timeout_seconds": 120,
        "stdin": "closed",
        "success_exit_codes": [0],
        "writes": [],
        "network": false,
        "destructive": false,
        "required_after": ["packaging_change", "template_version_change"]
      }
    }
  },
  "expect": {
    "validation_reasons": ["packaging_change", "template_version_change"],
    "runnable_intents": ["test_release"],
    "gap_reasons": [],
    "candidate_statuses": [
      {
        "reason": "packaging_change",
        "intent": "test_release",
        "status": "runnable",
        "skip_reason": null
      },
      {
        "reason": "template_version_change",
        "intent": "test_release",
        "status": "runnable",
        "skip_reason": null
      }
    ]
  }
}
