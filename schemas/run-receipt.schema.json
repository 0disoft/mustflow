{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/run-receipt.schema.json",
  "title": "mustflow run receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "intent",
    "status",
    "timed_out",
    "started_at",
    "finished_at",
    "duration_ms",
    "cwd",
    "lifecycle",
    "run_policy",
    "mode",
    "env_policy",
    "env_allowlist",
    "timeout_seconds",
    "max_output_bytes",
    "success_exit_codes",
    "exit_code",
    "signal",
    "error",
    "kill_method",
    "stdout",
    "stderr",
    "write_drift",
    "receipt_path"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "command": { "const": "run" },
    "intent": { "type": "string" },
    "status": { "enum": ["passed", "failed", "timed_out", "start_failed", "output_limit_exceeded"] },
    "timed_out": { "type": "boolean" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "duration_ms": { "type": "integer" },
    "cwd": { "type": "string" },
    "lifecycle": { "type": "string" },
    "run_policy": { "type": "string" },
    "mode": { "enum": ["argv", "shell"] },
    "env_policy": { "enum": ["inherit", "minimal", "allowlist"] },
    "env_allowlist": {
      "type": "array",
      "items": { "type": "string" }
    },
    "argv": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cmd": { "type": "string" },
    "timeout_seconds": { "type": "integer" },
    "max_output_bytes": { "type": "integer" },
    "success_exit_codes": {
      "type": "array",
      "items": { "type": "integer" }
    },
    "exit_code": { "type": ["integer", "null"] },
    "signal": { "type": ["string", "null"] },
    "error": { "type": ["string", "null"] },
    "kill_method": { "type": ["string", "null"] },
    "termination": { "$ref": "#/$defs/termination" },
    "stdout": { "$ref": "#/$defs/output" },
    "stderr": { "$ref": "#/$defs/output" },
    "write_drift": { "$ref": "#/$defs/writeDrift" },
    "performance": { "$ref": "#/$defs/performance" },
    "redaction": { "$ref": "#/$defs/redaction" },
    "verification_plan_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "receipt_path": { "type": "string" }
  },
  "$defs": {
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bytes", "truncated", "tail"],
      "properties": {
        "bytes": { "type": "integer" },
        "truncated": { "type": "boolean" },
        "tail": { "type": "string" },
        "redacted": { "type": "boolean" },
        "redaction_count": { "type": "integer" },
        "redaction_kinds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "performance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "measurement",
        "duration_ms",
        "timeout_ratio",
        "command_fingerprint",
        "intent_fingerprint",
        "contract_fingerprint",
        "runner",
        "output_summary",
        "result_summary",
        "quality"
      ],
      "properties": {
        "schema_version": { "const": "1" },
        "measurement": { "const": "wall_clock" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "executor_overhead_ms": { "type": "number", "minimum": 0 },
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "duration_ms"],
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
              "duration_ms": { "type": "number", "minimum": 0 }
            }
          }
        },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "strategy",
            "changed_file_count",
            "changed_surface_counts",
            "selected_target_count",
            "fallback_used"
          ],
          "properties": {
            "strategy": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
            "changed_file_count": { "type": "integer", "minimum": 0 },
            "changed_surface_counts": {
              "type": "object",
              "additionalProperties": {
                "type": "integer",
                "minimum": 0
              },
              "propertyNames": { "pattern": "^[a-z][a-z0-9_]*$" }
            },
            "selected_target_count": { "type": "integer", "minimum": 0 },
            "fallback_used": { "type": "boolean" }
          }
        },
        "timeout_ratio": { "type": "number", "minimum": 0 },
        "command_fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "intent_fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "contract_fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "runner": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "platform_family", "arch_family", "runtime", "runtime_major"],
          "properties": {
            "kind": { "const": "local" },
            "platform_family": { "type": "string" },
            "arch_family": { "type": "string" },
            "runtime": { "enum": ["node", "bun"] },
            "runtime_major": { "type": "integer", "minimum": 0 }
          }
        },
        "output_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["stdout_bytes", "stderr_bytes", "stdout_truncated", "stderr_truncated"],
          "properties": {
            "stdout_bytes": { "type": "integer", "minimum": 0 },
            "stderr_bytes": { "type": "integer", "minimum": 0 },
            "stdout_truncated": { "type": "boolean" },
            "stderr_truncated": { "type": "boolean" }
          }
        },
        "result_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "exit_code_class", "timed_out", "error_kind"],
          "properties": {
            "status": { "enum": ["passed", "failed", "timed_out", "start_failed", "output_limit_exceeded"] },
            "exit_code_class": { "enum": ["success", "failure", "no_exit_code"] },
            "timed_out": { "type": "boolean" },
            "error_kind": { "enum": ["timeout", "start_failed", "output_limit_exceeded", "exit_code", null] }
          }
        },
        "quality": {
          "type": "object",
          "additionalProperties": false,
          "required": ["phase_timings_source", "target_timings_source", "usable_for_history"],
          "properties": {
            "phase_timings_source": { "enum": ["none", "structured_report"] },
            "target_timings_source": { "const": "none" },
            "usable_for_history": { "type": "boolean" }
          }
        }
      }
    },
    "termination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "method",
        "graceful_signal",
        "forced_signal",
        "forced_kill_attempted",
        "confirmed",
        "cleanup_pending"
      ],
      "properties": {
        "reason": { "const": "timeout" },
        "method": { "type": "string" },
        "graceful_signal": { "type": ["string", "null"] },
        "forced_signal": { "type": ["string", "null"] },
        "forced_kill_attempted": { "type": "boolean" },
        "confirmed": { "type": "boolean" },
        "cleanup_pending": { "type": "boolean" }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["redacted", "redaction_count", "redaction_kinds", "fields"],
      "properties": {
        "redacted": { "type": "boolean" },
        "redaction_count": { "type": "integer" },
        "redaction_kinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "writeDrift": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "declared_paths",
        "observed_paths",
        "declared_observed_paths",
        "undeclared_paths",
        "observed_count",
        "undeclared_count",
        "has_undeclared_changes",
        "truncated",
        "reason"
      ],
      "properties": {
        "status": { "enum": ["checked", "unavailable"] },
        "declared_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "observed_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "declared_observed_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "undeclared_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "observed_count": { "type": "integer" },
        "undeclared_count": { "type": "integer" },
        "has_undeclared_changes": { "type": "boolean" },
        "truncated": { "type": "boolean" },
        "reason": { "type": ["string", "null"] }
      }
    }
  }
}
