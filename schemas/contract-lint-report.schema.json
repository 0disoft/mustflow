{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/contract-lint-report.schema.json",
  "title": "mustflow contract-lint report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "command", "mustflow_root", "report"],
  "properties": {
    "schema_version": { "const": "1" },
    "command": { "const": "contract-lint" },
    "mustflow_root": { "type": "string" },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary", "issues", "sourceFiles"],
      "properties": {
        "status": { "enum": ["passed", "warning", "failed"] },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "totalIntents",
            "configured",
            "runnable",
            "manualOnly",
            "unknown",
            "errors",
            "warnings"
          ],
          "properties": {
            "totalIntents": { "type": "integer" },
            "configured": { "type": "integer" },
            "runnable": { "type": "integer" },
            "manualOnly": { "type": "integer" },
            "unknown": { "type": "integer" },
            "errors": { "type": "integer" },
            "warnings": { "type": "integer" }
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["severity", "code", "intent", "message"],
            "properties": {
              "severity": { "enum": ["error", "warning"] },
              "code": { "type": "string" },
              "intent": { "type": ["string", "null"] },
              "message": { "type": "string" }
            }
          }
        },
        "sourceFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suggestions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "sourceFile",
              "sourceKind",
              "sourceName",
              "commandHint",
              "suggestedIntent",
              "status",
              "reason",
              "snippet"
            ],
            "properties": {
              "sourceFile": { "type": "string" },
              "sourceKind": {
                "enum": ["package_script", "make_target", "just_recipe"]
              },
              "sourceName": { "type": "string" },
              "commandHint": { "type": "string" },
              "suggestedIntent": { "type": "string" },
              "status": { "const": "unknown" },
              "reason": { "type": "string" },
              "snippet": { "type": "string" }
            }
          }
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "knownClassificationReasons",
            "documentedVerificationReasons",
            "requiredAfterReasons",
            "runnableReasons",
            "findings"
          ],
          "properties": {
            "knownClassificationReasons": {
              "type": "array",
              "items": { "type": "string" }
            },
            "documentedVerificationReasons": {
              "type": "array",
              "items": { "type": "string" }
            },
            "requiredAfterReasons": {
              "type": "array",
              "items": { "type": "string" }
            },
            "runnableReasons": {
              "type": "array",
              "items": { "type": "string" }
            },
            "matrix": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["reason", "source", "intents", "gaps", "relatedSkills", "relatedDocs"],
                "properties": {
                  "reason": { "type": "string" },
                  "source": { "enum": ["classification", "documented", "required_after"] },
                  "intents": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["intent", "status", "runnable", "detail"],
                      "properties": {
                        "intent": { "type": "string" },
                        "status": {
                          "enum": [
                            "ok",
                            "intent_not_table",
                            "status_not_configured",
                            "lifecycle_not_oneshot",
                            "run_policy_not_agent_allowed",
                            "stdin_not_closed",
                            "missing_timeout",
                            "missing_command_source",
                            "unsafe_intent_name",
                            "blocked_shell_background_pattern"
                          ]
                        },
                        "runnable": { "type": "boolean" },
                        "detail": { "type": ["string", "null"] }
                      }
                    }
                  },
                  "gaps": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "relatedSkills": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "relatedDocs": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            },
            "findings": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["severity", "code", "reason", "intent", "intents", "message"],
                "properties": {
                  "severity": { "enum": ["error", "warning"] },
                  "code": { "type": "string" },
                  "reason": { "type": ["string", "null"] },
                  "intent": { "type": ["string", "null"] },
                  "intents": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "message": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
