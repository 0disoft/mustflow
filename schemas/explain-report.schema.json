{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/explain-report.schema.json",
  "title": "mustflow explain report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "topic",
    "mustflow_root",
    "decision"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "command": { "const": "explain" },
    "topic": { "enum": ["anchor", "asset-optimization", "authority", "command", "retention", "skill", "skills", "surface", "verify", "why"] },
    "mustflow_root": { "type": "string" },
    "decision": {
      "oneOf": [
        { "$ref": "#/$defs/authorityDecision" },
        { "$ref": "#/$defs/commandDecision" },
        { "$ref": "#/$defs/retentionDecision" },
        { "$ref": "#/$defs/skillRouteDecision" },
        { "$ref": "#/$defs/skillRouteAlignmentDecision" },
        { "$ref": "#/$defs/publicSurfaceDecision" },
        { "$ref": "#/$defs/sourceAnchorDecision" },
        { "$ref": "#/$defs/verificationDecision" },
        { "$ref": "#/$defs/latestFailureDecision" }
      ]
    }
  },
  "$defs": {
    "sourceAnchorDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "inputAnchor",
        "decision",
        "reason",
        "effectiveAction",
        "countsAsMustflowVerification",
        "sourceFiles",
        "anchor"
      ],
      "properties": {
        "kind": { "enum": ["found", "missing"] },
        "inputAnchor": { "type": "string" },
        "decision": { "type": "string" },
        "reason": { "type": "string" },
        "effectiveAction": { "type": "string" },
        "countsAsMustflowVerification": { "const": false },
        "sourceFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "anchor": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": [
            "id",
            "path",
            "lineStart",
            "purpose",
            "search",
            "invariant",
            "risk",
            "navigationOnly",
            "canInstructAgent"
          ],
          "properties": {
            "id": { "type": "string" },
            "path": { "type": "string" },
            "lineStart": { "type": "integer" },
            "purpose": { "type": ["string", "null"] },
            "search": {
              "type": "array",
              "items": { "type": "string" }
            },
            "invariant": { "type": ["string", "null"] },
            "risk": {
              "type": "array",
              "items": { "type": "string" }
            },
            "navigationOnly": { "const": true },
            "canInstructAgent": { "const": false }
          }
        }
      }
    },
    "publicSurfaceDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "inputPath",
        "decision",
        "reason",
        "effectiveAction",
        "countsAsMustflowVerification",
        "sourceFiles",
        "surface"
      ],
      "properties": {
        "kind": { "enum": ["overview", "classified"] },
        "inputPath": { "type": ["string", "null"] },
        "decision": { "type": "string" },
        "reason": { "type": "string" },
        "effectiveAction": { "type": "string" },
        "countsAsMustflowVerification": { "const": false },
        "sourceFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "readModel": {
          "$ref": "#/$defs/localPathSurfaceReadModel"
        },
        "surface": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "category",
            "isPublicSurface",
            "validationReasons",
            "affectedContracts",
            "updatePolicy",
            "driftChecks"
          ],
          "properties": {
            "kind": { "type": "string" },
            "category": { "type": "string" },
            "isPublicSurface": { "type": "boolean" },
            "validationReasons": {
              "type": "array",
              "items": { "type": "string" }
            },
            "affectedContracts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "updatePolicy": { "enum": ["update", "update_or_mark_stale", "not_applicable"] },
            "driftChecks": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "localPathSurfaceReadModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "status",
        "databasePath",
        "indexFresh",
        "stalePaths",
        "inputPath",
        "match",
        "refreshHint"
      ],
      "properties": {
        "source": { "const": "local_index" },
        "status": { "enum": ["fresh", "missing", "stale", "unreadable"] },
        "databasePath": { "type": "string" },
        "indexFresh": { "type": "boolean" },
        "stalePaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inputPath": { "type": ["string", "null"] },
        "match": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/localPathSurfaceRuleMatch" }
          ]
        },
        "refreshHint": { "type": ["string", "null"] }
      }
    },
    "localPathSurfaceRuleMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleId",
        "patternKind",
        "pattern",
        "patternFlags",
        "changeKinds",
        "surface"
      ],
      "properties": {
        "ruleId": { "type": "string" },
        "patternKind": { "type": "string" },
        "pattern": { "type": "string" },
        "patternFlags": { "type": "string" },
        "changeKinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "surface": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "category",
            "isPublicSurface",
            "validationReasons",
            "affectedContracts",
            "updatePolicy",
            "driftChecks"
          ],
          "properties": {
            "kind": { "type": "string" },
            "category": { "type": "string" },
            "isPublicSurface": { "type": "boolean" },
            "validationReasons": {
              "type": "array",
              "items": { "type": "string" }
            },
            "affectedContracts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "updatePolicy": { "enum": ["update", "update_or_mark_stale", "not_applicable"] },
            "driftChecks": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "authorityDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "inputPath",
        "decision",
        "reason",
        "effectiveAction",
        "countsAsMustflowVerification",
        "sourceFiles",
        "expectation",
        "boundary"
      ],
      "properties": {
        "kind": { "enum": ["overview", "recognized", "unrecognized"] },
        "inputPath": { "type": ["string", "null"] },
        "decision": { "type": "string" },
        "reason": { "type": "string" },
        "effectiveAction": { "type": "string" },
        "countsAsMustflowVerification": { "type": "boolean" },
        "sourceFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expectation": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["docId", "authority", "lifecycle"],
          "properties": {
            "docId": { "type": "string" },
            "authority": { "type": "string" },
            "lifecycle": { "type": "string" }
          }
        },
        "boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["role", "canDefine", "cannotDefine"],
          "properties": {
            "role": { "type": "string" },
            "canDefine": {
              "type": "array",
              "items": { "type": "string" }
            },
            "cannotDefine": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "commandDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "inputCommand",
        "decision",
        "reason",
        "effectiveAction",
        "countsAsMustflowVerification",
        "sourceFiles",
        "intent"
      ],
      "properties": {
        "kind": { "enum": ["allowed", "blocked", "unknown"] },
        "inputCommand": { "type": "string" },
        "decision": { "type": "string" },
        "reason": { "type": "string" },
        "effectiveAction": { "type": "string" },
        "countsAsMustflowVerification": { "type": "boolean" },
        "sourceFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "intent": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": [
            "name",
            "status",
            "lifecycle",
            "runPolicy",
            "stdin",
            "timeoutSeconds",
            "mode",
            "cwd",
            "writes",
            "network",
            "destructive",
            "successExitCodes",
            "requiredAfter"
          ],
          "properties": {
            "name": { "type": "string" },
            "status": { "type": ["string", "null"] },
            "lifecycle": { "type": ["string", "null"] },
            "runPolicy": { "type": ["string", "null"] },
            "stdin": { "type": ["string", "null"] },
            "timeoutSeconds": { "type": ["integer", "null"] },
            "mode": { "enum": ["argv", "shell", "missing"] },
            "cwd": { "type": ["string", "null"] },
            "writes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "network": { "type": ["boolean", "null"] },
            "destructive": { "type": ["boolean", "null"] },
            "successExitCodes": {
              "type": "array",
              "items": { "type": "integer" }
            },
            "requiredAfter": {
              "type": "array",
              "items": { "type": "string" }
            },
            "preconditions": {
              "type": "array",
              "items": { "$ref": "#/$defs/commandPrecondition" }
            }
          }
        },
        "effectGraph": {
          "$ref": "#/$defs/commandEffectGraph"
        },
        "blockedRunPlan": {
          "$ref": "#/$defs/blockedRunPlan"
        }
      }
    },
    "blockedRunPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runnable",
        "reasonCode",
        "detail",
        "status",
        "lifecycle",
        "runPolicy",
        "configuredCwd",
        "timeoutSeconds",
        "mode",
        "writes",
        "suggestedIntentSnippet"
      ],
      "properties": {
        "runnable": { "type": "boolean" },
        "reasonCode": {
          "type": ["string", "null"],
          "enum": [
            "intent_not_table",
            "status_not_configured",
            "lifecycle_not_oneshot",
            "run_policy_not_agent_allowed",
            "stdin_not_closed",
            "missing_timeout",
            "missing_command_source",
            "unsafe_intent_name",
            "blocked_shell_background_pattern",
            "blocked_long_running_command_pattern",
            "cwd_outside_project",
            "max_output_bytes_exceeds_limit",
            null
          ]
        },
        "detail": { "type": ["string", "null"] },
        "status": { "type": ["string", "null"] },
        "lifecycle": { "type": ["string", "null"] },
        "runPolicy": { "type": ["string", "null"] },
        "configuredCwd": { "type": ["string", "null"] },
        "timeoutSeconds": { "type": ["integer", "null"] },
        "mode": { "type": ["string", "null"] },
        "writes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suggestedIntentSnippet": { "type": ["string", "null"] }
      }
    },
    "commandEffectGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "authority",
        "commandAuthority",
        "grantsCommandAuthority",
        "status",
        "databasePath",
        "indexFresh",
        "stalePaths",
        "writeLocks",
        "lockConflicts",
        "refreshHint"
      ],
      "properties": {
        "source": { "const": "local_index" },
        "authority": { "const": "explanation_only" },
        "commandAuthority": { "const": ".mustflow/config/commands.toml" },
        "grantsCommandAuthority": { "const": false },
        "status": { "enum": ["fresh", "missing", "stale", "unreadable"] },
        "databasePath": { "type": "string" },
        "indexFresh": { "type": "boolean" },
        "stalePaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "writeLocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/commandWriteLock" }
        },
        "lockConflicts": {
          "type": "array",
          "items": { "$ref": "#/$defs/commandLockConflict" }
        },
        "refreshHint": { "type": ["string", "null"] }
      }
    },
    "commandWriteLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lock", "paths", "modes", "sources", "concurrencies", "effectCount"],
      "properties": {
        "lock": { "type": "string" },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "modes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concurrencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "effectCount": { "type": "integer" }
      }
    },
    "commandLockConflict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent",
        "lock",
        "paths",
        "modes",
        "concurrencies",
        "conflictingPaths",
        "conflictingModes",
        "conflictingConcurrencies"
      ],
      "properties": {
        "intent": { "type": "string" },
        "lock": { "type": "string" },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "modes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concurrencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conflictingPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conflictingModes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conflictingConcurrencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "verificationDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "input",
        "decision",
        "reason",
        "effectiveAction",
        "countsAsMustflowVerification",
        "sourceFiles",
        "verification"
      ],
      "properties": {
        "kind": { "const": "verify" },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason", "planSource"],
          "properties": {
            "reason": { "type": ["string", "null"] },
            "planSource": { "type": ["string", "null"] }
          }
        },
        "decision": { "type": "string" },
        "reason": { "type": "string" },
        "effectiveAction": { "type": "string" },
        "countsAsMustflowVerification": { "const": false },
        "sourceFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "planSource",
            "reasons",
            "candidateCount",
            "runnableCount",
            "skippedCount",
            "requirements",
            "decisionGraph",
            "readModel"
          ],
          "properties": {
            "planSource": { "type": ["string", "null"] },
            "reasons": {
              "type": "array",
              "items": { "type": "string" }
            },
            "candidateCount": { "type": "integer" },
            "runnableCount": { "type": "integer" },
            "skippedCount": { "type": "integer" },
            "requirements": {
              "type": "array",
              "items": { "$ref": "#/$defs/verificationRequirement" }
            },
            "decisionGraph": {
              "$ref": "#/$defs/verificationDecisionGraph"
            },
            "readModel": {
              "$ref": "#/$defs/localVerificationReadModel"
            }
          }
        }
      }
    },
    "localVerificationReadModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "authority",
        "commandAuthority",
        "grantsCommandAuthority",
        "status",
        "databasePath",
        "indexFresh",
        "stalePaths",
        "planId",
        "uncoveredCriteria",
        "severeRisks",
        "nonPassingReceipts",
        "repeatedFailureFingerprints",
        "validationWeakeningSignals",
        "refreshHint"
      ],
      "properties": {
        "source": { "const": "local_index" },
        "authority": { "const": "evidence_only" },
        "commandAuthority": { "const": ".mustflow/config/commands.toml" },
        "grantsCommandAuthority": { "const": false },
        "status": { "enum": ["fresh", "missing", "stale", "unreadable"] },
        "databasePath": { "type": "string" },
        "indexFresh": { "type": "boolean" },
        "stalePaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "planId": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "uncoveredCriteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/localUncoveredCriterion" }
        },
        "severeRisks": {
          "type": "array",
          "items": { "$ref": "#/$defs/localSevereVerificationRisk" }
        },
        "nonPassingReceipts": {
          "type": "array",
          "items": { "$ref": "#/$defs/localNonPassingVerificationReceipt" }
        },
        "repeatedFailureFingerprints": {
          "type": "array",
          "items": { "$ref": "#/$defs/localRepeatedFailureFingerprint" }
        },
        "validationWeakeningSignals": {
          "type": "array",
          "items": { "$ref": "#/$defs/localValidationWeakeningSignal" }
        },
        "refreshHint": { "type": ["string", "null"] }
      }
    },
    "localUncoveredCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterionId",
        "source",
        "reason",
        "surface",
        "pathHash",
        "coverageStatus",
        "receiptCount",
        "gapCount",
        "riskCount"
      ],
      "properties": {
        "criterionId": { "type": "string" },
        "source": { "type": "string" },
        "reason": { "type": ["string", "null"] },
        "surface": { "type": ["string", "null"] },
        "pathHash": { "type": ["string", "null"] },
        "coverageStatus": { "type": ["string", "null"] },
        "receiptCount": { "type": "integer" },
        "gapCount": { "type": "integer" },
        "riskCount": { "type": "integer" }
      }
    },
    "localSevereVerificationRisk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourcePath", "ordinal", "code", "severity", "detailHash"],
      "properties": {
        "sourcePath": { "type": "string" },
        "ordinal": { "type": "integer" },
        "code": { "type": "string" },
        "severity": { "type": "string" },
        "detailHash": { "type": "string" }
      }
    },
    "localNonPassingVerificationReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receiptHash",
        "planId",
        "intent",
        "status",
        "commandFingerprint",
        "contractFingerprint",
        "currentStateHash",
        "writeDriftStatus"
      ],
      "properties": {
        "receiptHash": { "type": "string" },
        "planId": { "type": "string" },
        "intent": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "commandFingerprint": { "type": ["string", "null"] },
        "contractFingerprint": { "type": ["string", "null"] },
        "currentStateHash": { "type": ["string", "null"] },
        "writeDriftStatus": { "type": ["string", "null"] }
      }
    },
    "localRepeatedFailureFingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourcePath",
        "fingerprint",
        "verificationPlanId",
        "status",
        "failedIntents",
        "primaryReason",
        "failedIntentsHash",
        "riskCodesHash",
        "affectedSurfacesHash",
        "seenCount",
        "requiresNewEvidence"
      ],
      "properties": {
        "sourcePath": { "type": "string" },
        "fingerprint": { "type": "string" },
        "verificationPlanId": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "failedIntents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "primaryReason": { "type": ["string", "null"] },
        "failedIntentsHash": { "type": ["string", "null"] },
        "riskCodesHash": { "type": ["string", "null"] },
        "affectedSurfacesHash": { "type": ["string", "null"] },
        "seenCount": { "type": "integer" },
        "requiresNewEvidence": { "type": "boolean" }
      }
    },
    "localValidationWeakeningSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signalId", "planId", "code", "severity", "pathHash", "beforeHash", "afterHash"],
      "properties": {
        "signalId": { "type": "string" },
        "planId": { "type": ["string", "null"] },
        "code": { "type": "string" },
        "severity": { "type": "string" },
        "pathHash": { "type": "string" },
        "beforeHash": { "type": ["string", "null"] },
        "afterHash": { "type": ["string", "null"] }
      }
    },
    "verificationDecisionGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "root", "summary", "nodes", "edges"],
      "properties": {
        "schema_version": { "const": "1" },
        "root": { "const": "verification_decision" },
        "summary": { "$ref": "#/$defs/verificationDecisionGraphSummary" },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/verificationDecisionGraphNode" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/verificationDecisionGraphEdge" }
        }
      }
    },
    "verificationDecisionGraphSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodeCount",
        "edgeCount",
        "runnable",
        "skipped",
        "blocked",
        "manual_only",
        "unknown",
        "gapCount"
      ],
      "properties": {
        "nodeCount": { "type": "integer" },
        "edgeCount": { "type": "integer" },
        "runnable": { "type": "integer" },
        "skipped": { "type": "integer" },
        "blocked": { "type": "integer" },
        "manual_only": { "type": "integer" },
        "unknown": { "type": "integer" },
        "selected": { "type": "integer" },
        "not_selected": { "type": "integer" },
        "gapCount": { "type": "integer" }
      }
    },
    "verificationDecisionGraphNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "label", "status", "reason", "intent", "data"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "enum": [
            "changed_surface",
            "classification_reason",
            "command_candidate",
            "eligibility",
            "effect",
            "gap",
            "receipt"
          ]
        },
        "label": { "type": "string" },
