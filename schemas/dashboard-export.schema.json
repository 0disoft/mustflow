{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/dashboard-export.schema.json",
  "title": "mustflow dashboard export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "format",
    "generated_at",
    "mustflow_root",
    "output_policy",
    "limits",
    "preferences",
    "status",
    "docs_review",
    "harness_report"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "command": { "const": "dashboard export" },
    "format": { "enum": ["html", "json"] },
    "generated_at": { "type": "string" },
    "mustflow_root": { "type": "string" },
    "output_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bounded_to_mustflow_root",
        "starts_server",
        "static_html",
        "contains_mutation_controls",
        "omits_dashboard_token",
        "omits_raw_run_output",
        "redacts_secret_like_values"
      ],
      "properties": {
        "bounded_to_mustflow_root": { "const": true },
        "starts_server": { "const": false },
        "static_html": { "type": "boolean" },
        "contains_mutation_controls": { "const": false },
        "omits_dashboard_token": { "const": true },
        "omits_raw_run_output": { "const": true },
        "redacts_secret_like_values": { "const": true }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_string_bytes",
        "max_array_items",
        "max_depth",
        "truncated_fields",
        "omitted_fields",
        "redacted_fields",
        "redaction_count",
        "redaction_kinds"
      ],
      "properties": {
        "max_string_bytes": { "type": "integer" },
        "max_array_items": { "type": "integer" },
        "max_depth": { "type": "integer" },
        "truncated_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "omitted_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "redacted_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "redaction_count": { "type": "integer" },
        "redaction_kinds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "preferences": {
      "type": "object",
      "additionalProperties": true
    },
    "status": {
      "type": "object",
      "additionalProperties": true
    },
    "docs_review": {
      "type": "object",
      "additionalProperties": true
    },
    "harness_report": { "$ref": "#/$defs/harnessReport" }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "decisionGraphSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "node_count",
        "edge_count",
        "runnable",
        "skipped",
        "blocked",
        "manual_only",
        "unknown",
        "gap_count"
      ],
      "properties": {
        "root": { "const": "verification_decision" },
        "node_count": { "type": "integer" },
        "edge_count": { "type": "integer" },
        "runnable": { "type": "integer" },
        "skipped": { "type": "integer" },
        "blocked": { "type": "integer" },
        "manual_only": { "type": "integer" },
        "unknown": { "type": "integer" },
        "gap_count": { "type": "integer" }
      }
    },
    "verificationGap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "intent", "reason", "detail", "files", "surfaces"],
      "properties": {
        "kind": { "enum": ["manual_only", "blocked", "unknown", "missing"] },
        "intent": { "type": ["string", "null"] },
        "reason": { "type": ["string", "null"] },
        "detail": { "type": ["string", "null"] },
        "files": { "$ref": "#/$defs/stringArray" },
        "surfaces": { "$ref": "#/$defs/stringArray" }
      }
    },
    "remainingRisk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "detail"],
      "properties": {
        "code": { "type": "string" },
        "severity": { "enum": ["info", "warning", "error"] },
        "detail": { "type": "string" },
        "count": { "type": "integer" },
        "paths": { "$ref": "#/$defs/stringArray" }
      }
    },
    "evidenceModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "source",
        "verification_plan_id",
        "requirements",
        "coverage_matrix",
        "receipts",
        "skipped_checks",
        "gaps",
        "remaining_risks",
        "explanation"
      ],
      "properties": {
        "schema_version": { "const": "1" },
        "source": { "enum": ["mf_verify", "dashboard_export"] },
        "verification_plan_id": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRequirement" }
        },
        "coverage_matrix": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceCoverageCriterion" }
        },
        "receipts": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceReceipt" }
        },
        "skipped_checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceSkippedCheck" }
        },
        "gaps": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceGap" }
        },
        "remaining_risks": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRemainingRisk" }
        },
        "explanation": { "$ref": "#/$defs/evidenceExplanation" }
      }
    },
    "evidenceRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "files",
        "surfaces",
        "candidate_intents",
        "selected_intents",
        "skipped_intents",
        "gap_count",
        "outcome"
      ],
      "properties": {
        "reason": { "type": "string" },
        "files": { "$ref": "#/$defs/stringArray" },
        "surfaces": { "$ref": "#/$defs/stringArray" },
        "candidate_intents": { "$ref": "#/$defs/stringArray" },
        "selected_intents": { "$ref": "#/$defs/stringArray" },
        "skipped_intents": { "$ref": "#/$defs/stringArray" },
        "gap_count": { "type": "integer" },
        "outcome": { "enum": ["verified", "partially_verified", "unverified", "blocked", "contradicted"] }
      }
    },
    "evidenceCoverageCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion_id", "source", "statement", "status", "requirement_reason", "evidence"],
      "properties": {
        "criterion_id": { "type": "string" },
        "source": { "enum": ["verification_requirement", "dashboard_snapshot"] },
        "statement": { "type": "string" },
        "status": { "enum": ["covered", "partially_covered", "uncovered", "blocked", "contradicted"] },
        "requirement_reason": { "type": ["string", "null"] },
        "evidence": { "$ref": "#/$defs/evidenceCoverageLinks" }
      }
    },
    "evidenceCoverageLinks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intents", "receipt_paths", "gap_reasons", "source_anchor_ids"],
      "properties": {
        "intents": { "$ref": "#/$defs/stringArray" },
        "receipt_paths": { "$ref": "#/$defs/stringArray" },
        "gap_reasons": { "$ref": "#/$defs/stringArray" },
        "source_anchor_ids": { "$ref": "#/$defs/stringArray" }
      }
    },
    "evidenceReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "status", "skipped", "verification_plan_id", "receipt_path", "receipt_sha256"],
      "properties": {
        "intent": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "skipped": { "type": "boolean" },
        "verification_plan_id": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "receipt_path": { "type": ["string", "null"] },
        "receipt_sha256": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "evidenceSkippedCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "reason", "detail"],
      "properties": {
        "intent": { "type": ["string", "null"] },
        "reason": { "type": ["string", "null"] },
        "detail": { "type": ["string", "null"] }
      }
    },
    "evidenceGap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "intent", "status", "detail", "files", "surfaces"],
      "properties": {
        "reason": { "type": ["string", "null"] },
        "intent": { "type": ["string", "null"] },
        "status": { "type": ["string", "null"] },
        "detail": { "type": ["string", "null"] },
        "files": { "$ref": "#/$defs/stringArray" },
        "surfaces": { "$ref": "#/$defs/stringArray" }
      }
    },
    "evidenceRemainingRisk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "detail"],
      "properties": {
        "code": { "type": "string" },
        "severity": { "type": "string" },
        "detail": { "type": "string" }
      }
    },
    "evidenceExplanation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verified_by", "downgraded_by", "blocked_by", "contradicted_by"],
      "properties": {
        "verified_by": { "$ref": "#/$defs/stringArray" },
        "downgraded_by": { "$ref": "#/$defs/stringArray" },
        "blocked_by": { "$ref": "#/$defs/stringArray" },
        "contradicted_by": { "$ref": "#/$defs/stringArray" }
      }
    },
    "completionVerdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "status", "primary_reason", "evidence", "blockers", "contradictions", "limitations"],
      "properties": {
        "schema_version": { "const": "1" },
        "status": { "enum": ["verified", "partially_verified", "unverified", "blocked", "contradicted"] },
        "primary_reason": { "type": "string" },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "verification_plan_id",
            "changed_file_count",
            "criteria",
            "matched_intents",
            "ran_intents",
            "passed_intents",
            "failed_intents",
            "skipped_intents",
            "receipt_count",
            "gap_count",
            "source_anchor_risk_count",
            "scope_diff_risk_count",
            "repeated_failure_count",
            "validation_ratchet_risk_count",
            "repro_evidence_risk_count",
            "external_evidence_risk_count",
            "write_drift_risk_count",
            "receipt_binding_risk_count",
            "stale_receipt_count",
            "plan_mismatch_count",
            "risks",
            "receipt_binding",
            "latest_run_status"
          ],
          "properties": {
            "source": { "enum": ["mf_verify", "dashboard_export"] },
            "verification_plan_id": {
              "type": ["string", "null"],
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "changed_file_count": { "type": ["integer", "null"] },
            "criteria": { "$ref": "#/$defs/completionVerdictCriteria" },
            "matched_intents": { "type": "integer" },
            "ran_intents": { "type": "integer" },
            "passed_intents": { "type": "integer" },
            "failed_intents": { "type": "integer" },
            "skipped_intents": { "type": "integer" },
            "receipt_count": { "type": "integer" },
            "gap_count": { "type": "integer" },
            "source_anchor_risk_count": { "type": "integer" },
            "scope_diff_risk_count": { "type": "integer" },
            "repeated_failure_count": { "type": "integer" },
            "validation_ratchet_risk_count": { "type": "integer" },
            "repro_evidence_risk_count": { "type": "integer" },
            "external_evidence_risk_count": { "type": "integer" },
            "write_drift_risk_count": { "type": "integer" },
            "receipt_binding_risk_count": { "type": "integer" },
            "stale_receipt_count": { "type": "integer" },
            "plan_mismatch_count": { "type": "integer" },
            "risks": { "$ref": "#/$defs/completionVerdictRisks" },
            "receipt_binding": { "$ref": "#/$defs/completionVerdictReceiptBinding" },
            "latest_run_status": { "type": ["string", "null"] }
          }
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "contradictions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "completionVerdictCriteria": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "covered", "partially_covered", "uncovered", "blocked", "contradicted"],
      "properties": {
        "total": { "type": "integer" },
        "covered": { "type": "integer" },
        "partially_covered": { "type": "integer" },
        "uncovered": { "type": "integer" },
        "blocked": { "type": "integer" },
        "contradicted": { "type": "integer" }
      }
    },
    "completionVerdictRisks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_anchor",
        "scope_diff",
        "repeated_failure",
        "validation_ratchet",
        "repro_evidence",
        "external_evidence",
        "write_drift",
        "receipt_binding",
        "stale_receipt",
        "plan_mismatch"
      ],
      "properties": {
        "source_anchor": { "type": "integer" },
        "scope_diff": { "type": "integer" },
        "repeated_failure": { "type": "integer" },
        "validation_ratchet": { "type": "integer" },
        "repro_evidence": { "type": "integer" },
        "external_evidence": { "type": "integer" },
        "write_drift": { "type": "integer" },
        "receipt_binding": { "type": "integer" },
        "stale_receipt": { "type": "integer" },
        "plan_mismatch": { "type": "integer" }
      }
    },
    "completionVerdictReceiptBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_bound_count",
        "plan_unbound_count",
        "fingerprint_bound_count",
        "fingerprint_unbound_count",
        "current_state_bound_count",
        "current_state_unavailable_count",
        "stale_count",
        "plan_mismatch_count"
      ],
      "properties": {
        "plan_bound_count": { "type": "integer" },
        "plan_unbound_count": { "type": "integer" },
        "fingerprint_bound_count": { "type": "integer" },
        "fingerprint_unbound_count": { "type": "integer" },
        "current_state_bound_count": { "type": "integer" },
        "current_state_unavailable_count": { "type": "integer" },
        "stale_count": { "type": "integer" },
        "plan_mismatch_count": { "type": "integer" }
      }
    },
    "harnessReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "generated_from",
        "install",
        "verification",
        "run_history",
        "docs_review",
        "remaining_risks"
      ],
      "properties": {
        "schema_version": { "const": "1" },
        "generated_from": { "const": "dashboard_status_snapshot" },
        "install": {
          "type": "object",
          "additionalProperties": false,
          "required": ["installed", "manifest_lock", "tracked_files", "changed_files", "missing_files", "issues"],
          "properties": {
            "installed": { "type": "boolean" },
            "manifest_lock": { "type": "string" },
            "tracked_files": { "type": "integer" },
            "changed_files": { "type": "integer" },
            "missing_files": { "type": "integer" },
            "issues": { "type": "integer" }
          }
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "completion_verdict",
            "evidence_model",
            "changed_file_count",
            "changed_surfaces",
            "decision_graph_summary",
            "runnable_intents",
            "skipped_intents",
            "gaps"
          ],
          "properties": {
            "completion_verdict": { "$ref": "#/$defs/completionVerdict" },
            "evidence_model": { "$ref": "#/$defs/evidenceModel" },
            "changed_file_count": { "type": "integer" },
            "changed_surfaces": { "$ref": "#/$defs/stringArray" },
            "decision_graph_summary": {
              "type": ["object", "null"],
              "properties": {
                "root": { "const": "verification_decision" },
                "node_count": { "type": "integer" },
                "edge_count": { "type": "integer" },
                "runnable": { "type": "integer" },
                "skipped": { "type": "integer" },
                "blocked": { "type": "integer" },
                "manual_only": { "type": "integer" },
                "unknown": { "type": "integer" },
                "gap_count": { "type": "integer" }
              }
            },
            "runnable_intents": { "$ref": "#/$defs/stringArray" },
            "skipped_intents": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["intent", "reason_key"],
                "properties": {
                  "intent": { "type": "string" },
                  "reason_key": { "type": "string" }
                }
              }
            },
            "gaps": {
              "type": "array",
              "items": { "$ref": "#/$defs/verificationGap" }
            }
          }
        },
        "run_history": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "exists",
            "valid",
            "intent",
            "status",
            "exit_code",
            "timed_out",
            "finished_at",
            "duration_ms",
            "receipt_path"
          ],
          "properties": {
            "path": { "type": "string" },
            "exists": { "type": "boolean" },
            "valid": { "type": "boolean" },
            "intent": { "type": ["string", "null"] },
            "status": { "type": ["string", "null"] },
            "exit_code": { "type": ["integer", "null"] },
            "timed_out": { "type": ["boolean", "null"] },
            "finished_at": { "type": ["string", "null"] },
            "duration_ms": { "type": ["number", "null"] },
            "receipt_path": { "type": ["string", "null"] }
          }
        },
        "docs_review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ledger_path", "active_documents"],
          "properties": {
            "ledger_path": { "type": "string" },
            "active_documents": { "type": "integer" }
          }
        },
        "remaining_risks": {
          "type": "array",
          "items": { "$ref": "#/$defs/remainingRisk" }
        }
      }
    }
  }
}
