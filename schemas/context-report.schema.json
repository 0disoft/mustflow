        "measured_block_count": { "type": "integer", "minimum": 0 },
        "dynamic_source_count": { "type": "integer", "minimum": 0 },
        "unresolved_reference_count": { "type": "integer", "minimum": 0 },
        "volatile_before_stable_count": { "type": "integer", "minimum": 0 },
