{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/context-report.schema.json",
  "title": "mustflow context report",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/agentContextReport" },
    { "$ref": "#/$defs/promptCacheProfileReport" }
  ],
  "$defs": {
    "agentContextReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "command",
        "mustflow_root",
        "installed",
        "manifest_lock",
        "template",
        "authority",
        "capabilities",
        "read_order",
        "optional_read_order",
        "command_contract",
        "effective_policy",
        "state_policy",
        "blocked_actions",
        "latest_run",
        "issues"
      ],
      "properties": {
        "schema_version": { "const": "1" },
        "command": { "const": "context" },
        "mustflow_root": { "type": "string" },
        "installed": { "type": "boolean" },
        "manifest_lock": { "enum": ["missing", "invalid", "present"] },
        "template": { "$ref": "#/$defs/templateContext" },
        "authority": { "$ref": "#/$defs/scalarObject" },
        "capabilities": { "$ref": "#/$defs/scalarObject" },
        "read_order": {
          "type": "array",
          "items": { "$ref": "#/$defs/pathContext" }
        },
        "optional_read_order": {
          "type": "array",
          "items": { "$ref": "#/$defs/pathContext" }
        },
        "command_contract": { "$ref": "#/$defs/commandContractContext" },
        "technology_preferences": { "$ref": "#/$defs/technologyPreferencesContext" },
        "effective_policy": { "$ref": "#/$defs/effectivePolicy" },
        "state_policy": { "$ref": "#/$defs/statePolicy" },
        "blocked_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "latest_run": { "$ref": "#/$defs/latestRun" },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "promptCacheProfileReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "command",
        "cache_profile",
        "prompt_cache",
        "issues"
      ],
      "properties": {
        "schema_version": { "const": "1" },
        "command": { "const": "context" },
        "cache_profile": { "enum": ["stable", "task", "volatile", "all"] },
        "prompt_cache": { "$ref": "#/$defs/promptCacheSettings" },
        "stable_prefix": { "$ref": "#/$defs/stablePrefixLayer" },
        "task_context": { "$ref": "#/$defs/taskContextLayer" },
        "volatile_suffix": { "$ref": "#/$defs/volatileSuffixLayer" },
        "prompt_bundle": { "$ref": "#/$defs/promptBundle" },
        "prompt_bundle_diff": { "$ref": "#/$defs/promptBundleDiff" },
        "cache_audit": { "$ref": "#/$defs/promptCacheAudit" },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "templateContext": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "version"],
          "properties": {
            "id": { "type": "string" },
            "version": { "type": "string" }
          }
        }
      ]
    },
    "scalar": { "type": ["string", "number", "boolean", "null"] },
    "scalarObject": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          { "$ref": "#/$defs/scalar" },
          {
            "type": "array",
            "items": { "$ref": "#/$defs/scalar" }
          }
        ]
      }
    },
    "pathContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists"],
      "properties": {
        "path": { "type": "string" },
        "exists": { "type": "boolean" },
        "trust": { "$ref": "#/$defs/contextTrust" }
      }
    },
    "contextTrust": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "authority",
        "cache_layer",
        "freshness",
        "content_hash",
        "can_instruct_agent",
        "grants_command_authority",
        "notes"
      ],
      "properties": {
        "source_kind": {
          "enum": [
            "workflow_file",
            "command_contract",
            "skill_file",
            "context_file",
            "generated_cache",
            "generated_state",
            "source_placeholder",
            "runtime_volatile",
            "unknown_file"
          ]
        },
        "authority": {
          "enum": [
            "binding",
            "workflow_policy",
            "configuration",
            "command_contract",
            "procedure",
            "contextual",
            "hint",
            "generated",
            "evidence_only",
            "volatile",
            "unknown"
          ]
        },
        "cache_layer": { "enum": ["stable", "task", "volatile", null] },
        "freshness": { "enum": ["hash_verified", "missing", "dynamic", "runtime_volatile", "unchecked"] },
        "content_hash": { "type": ["string", "null"] },
        "can_instruct_agent": { "type": "boolean" },
        "grants_command_authority": { "type": "boolean" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "intentContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "lifecycle", "run_policy", "description"],
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "lifecycle": { "type": ["string", "null"] },
        "run_policy": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] }
      }
    },
    "commandContractContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists", "intents", "runnable_intents"],
      "properties": {
        "path": { "type": "string" },
        "exists": { "type": "boolean" },
        "intents": {
          "type": "array",
          "items": { "$ref": "#/$defs/intentContext" }
        },
        "runnable_intents": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "technologyPreference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "name",
        "status",
        "authority",
        "scope",
        "ecosystem",
        "packages",
        "rationale",
        "constraints"
      ],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["language", "runtime", "framework", "library", "tool", "service", "platform"] },
        "name": { "type": "string" },
        "status": { "enum": ["preferred", "allowed", "avoid"] },
        "authority": { "const": "hint" },
        "scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ecosystem": { "type": ["string", "null"] },
        "packages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rationale": { "type": ["string", "null"] },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "technologyPreferencesContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists", "authority", "guidance", "count", "preferences", "issues"],
      "properties": {
        "path": { "type": "string" },
        "exists": { "type": "boolean" },
        "authority": { "const": "hint" },
        "guidance": {
          "type": "array",
          "items": { "type": "string" }
        },
        "count": { "type": "integer", "minimum": 0 },
        "preferences": {
          "type": "array",
          "items": { "$ref": "#/$defs/technologyPreference" }
        },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "effectivePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entrypoint",
        "nearest_agents",
        "command_contract",
        "project_commands_require_mf_run",
        "allow_inferred_commands",
        "auto_stage",
        "auto_commit",
        "auto_push",
        "state_is_versioned",
        "raw_logs_allowed"
      ],
      "properties": {
        "entrypoint": { "type": "string" },
        "nearest_agents": { "type": "string" },
        "command_contract": { "type": "string" },
        "project_commands_require_mf_run": { "type": "boolean" },
        "allow_inferred_commands": { "type": "boolean" },
        "auto_stage": { "type": "boolean" },
        "auto_commit": { "type": "boolean" },
        "auto_push": { "type": "boolean" },
        "state_is_versioned": { "type": "boolean" },
        "raw_logs_allowed": { "type": "boolean" }
      }
    },
    "statePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cache_path",
        "state_path",
        "versioned",
        "safe_to_delete",
        "stores_raw_conversation",
        "stores_full_terminal_output",
        "stores_hidden_chain_of_thought"
      ],
      "properties": {
        "cache_path": { "type": "string" },
        "state_path": { "type": "string" },
        "versioned": { "type": "boolean" },
        "safe_to_delete": { "type": "boolean" },
        "stores_raw_conversation": { "type": "boolean" },
        "stores_full_terminal_output": { "type": "boolean" },
        "stores_hidden_chain_of_thought": { "type": "boolean" }
      }
    },
    "latestRun": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "exists"],
          "properties": {
            "path": { "type": "string" },
            "exists": { "const": false }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "exists", "valid", "error"],
          "properties": {
            "path": { "type": "string" },
            "exists": { "const": true },
            "valid": { "const": false },
            "error": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "exists",
            "valid",
            "intent",
            "status",
            "timed_out",
            "exit_code",
            "finished_at",
            "duration_ms"
          ],
          "properties": {
            "path": { "type": "string" },
            "exists": { "const": true },
            "valid": { "const": true },
            "intent": { "type": "string" },
            "status": { "type": "string" },
            "timed_out": { "type": "boolean" },
            "exit_code": { "type": ["integer", "null"] },
            "finished_at": { "type": ["string", "null"] },
            "duration_ms": { "type": ["integer", "null"] }
          }
        }
      ]
    },
    "promptCacheSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "strategy",
        "stable_prefix_policy",
        "prefer_references_when_unchanged",
        "exclude_volatile_state_from_prefix",
        "include_content_hashes",
        "max_stable_prefix_kb",
        "max_task_context_kb",
        "max_volatile_suffix_kb"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "strategy": { "type": ["string", "null"] },
        "stable_prefix_policy": { "type": ["string", "null"] },
        "prefer_references_when_unchanged": { "type": "boolean" },
        "exclude_volatile_state_from_prefix": { "type": "boolean" },
        "include_content_hashes": { "type": "boolean" },
        "max_stable_prefix_kb": { "type": ["integer", "null"] },
        "max_task_context_kb": { "type": ["integer", "null"] },
        "max_volatile_suffix_kb": { "type": ["integer", "null"] }
      }
    },
    "stablePrefixLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cache_layer", "cache_key", "policy", "documents", "volatile_excluded"],
      "properties": {
        "cache_layer": { "const": "stable" },
        "cache_key": { "type": ["string", "null"] },
        "policy": { "type": ["string", "null"] },
        "documents": {
          "type": "array",
          "items": { "$ref": "#/$defs/promptCacheDocument" }
        },
        "volatile_excluded": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "promptCacheDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists", "content_hash"],
      "properties": {
        "path": { "type": "string" },
        "exists": { "type": "boolean" },
        "content_hash": { "type": ["string", "null"] },
        "trust": { "$ref": "#/$defs/contextTrust" }
      }
    },
    "taskContextLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cache_layer", "read_policy", "sources", "local_index"],
      "properties": {
        "cache_layer": { "const": "task" },
        "read_policy": { "type": ["string", "null"] },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "route_read_plan": { "$ref": "#/$defs/taskRouteReadPlan" },
        "repo_map_read_plan": { "$ref": "#/$defs/taskRepoMapReadPlan" },
        "local_index": { "$ref": "#/$defs/promptCacheLocalIndex" }
      }
    },
    "taskRouteReadPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolver_command",
        "stable_kernel",
        "route_sources",
        "selected_skill_paths_source",
        "route_metadata_fallback",
        "expanded_index_fallback",
        "selection_limits"
      ],
      "properties": {
        "resolver_command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stable_kernel": {
          "type": "array",
          "items": { "type": "string" }
        },
        "route_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "selected_skill_paths_source": { "type": "string" },
        "route_metadata_fallback": { "$ref": "#/$defs/taskRouteFallback" },
        "expanded_index_fallback": { "$ref": "#/$defs/taskRouteFallback" },
        "selection_limits": { "$ref": "#/$defs/taskRouteSelectionLimits" }
      }
    },
    "taskRouteFallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "read_when", "avoid_by_default"],
      "properties": {
        "path": { "type": "string" },
        "read_when": {
          "type": "array",
          "items": { "type": "string" }
        },
        "avoid_by_default": { "type": "boolean" }
      }
    },
    "taskRouteSelectionLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidates", "main", "adjuncts"],
      "properties": {
        "candidates": { "type": "integer", "minimum": 0 },
        "main": { "type": "integer", "minimum": 0 },
        "adjuncts": { "type": "integer", "minimum": 0 }
      }
    },
    "taskRepoMapReadPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "strategy", "anchor_sources", "fallback"],
      "properties": {
        "source": { "const": "repo_map_navigation" },
        "strategy": { "const": "select_anchors_or_spans_before_full_map" },
        "anchor_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fallback": { "$ref": "#/$defs/taskRouteFallback" }
      }
    },
    "promptCacheLocalIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "status",
        "database_path",
        "index_fresh",
        "stale_paths",
        "search_backend",
        "search_fts5_available",
        "refresh_hint"
      ],
      "properties": {
        "source": { "const": "local_index" },
        "status": { "enum": ["fresh", "missing", "stale", "unreadable"] },
        "database_path": { "type": "string" },
        "index_fresh": { "type": "boolean" },
        "stale_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "search_backend": { "type": ["string", "null"], "enum": ["fts5", "table_scan", null] },
        "search_fts5_available": { "type": ["boolean", "null"] },
        "refresh_hint": { "type": ["string", "null"] }
      }
    },
    "volatileSuffixLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cache_layer",
        "sources",
        "never_place_before_stable_prefix",
        "include_absolute_root",
        "include_latest_run"
      ],
      "properties": {
        "cache_layer": { "const": "volatile" },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "never_place_before_stable_prefix": { "type": "boolean" },
        "include_absolute_root": { "const": false },
        "include_latest_run": { "const": false }
      }
    },
    "promptCacheAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["measurement", "estimator", "canonicalization", "summary", "layers", "issues"],
      "properties": {
        "measurement": { "const": "reference_bundle" },
        "estimator": { "$ref": "#/$defs/promptCacheAuditEstimator" },
        "canonicalization": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary": { "$ref": "#/$defs/promptCacheAuditSummary" },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/promptCacheAuditLayer" }
        },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "promptBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "renderer",
        "content_included",
        "request_shape_hash",
        "bundle_hash",
        "layers",
        "issues"
      ],
      "properties": {
        "schema_version": { "const": "1" },
        "renderer": { "const": "reference_bundle_utf8_lf_v1" },
        "content_included": { "const": false },
        "request_shape_hash": { "type": "string" },
        "bundle_hash": { "type": "string" },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/promptBundleLayer" }
        },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "promptBundleLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cache_layer", "blocks"],
      "properties": {
        "cache_layer": { "enum": ["stable", "task", "volatile"] },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/promptBundleBlock" }
        }
      }
    },
    "promptBundleBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "cache_layer",
        "order",
        "kind",
        "path",
        "source",
        "source_kind",
        "selection_policy",
        "content_included",
        "content_hash",
        "rendered_digest",
        "rendered_bytes",
        "estimated_tokens",
        "cacheability",
        "reload_on",
        "issue"
      ],
      "properties": {
        "id": { "type": "string" },
        "cache_layer": { "enum": ["stable", "task", "volatile"] },
        "order": { "type": "integer", "minimum": 1 },
        "kind": { "enum": ["file", "source_placeholder"] },
        "path": { "type": ["string", "null"] },
        "source": { "type": ["string", "null"] },
        "source_kind": { "enum": ["file_reference", "dynamic_selection", "runtime_volatile"] },
        "selection_policy": {
          "enum": [
            "always_rendered",
            "read_when_selected",
            "fallback_when_needed",
            "selected_at_runtime",
            "volatile_runtime"
          ]
        },
        "content_included": { "const": false },
        "content_hash": { "type": ["string", "null"] },
        "rendered_digest": { "type": ["string", "null"] },
        "rendered_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "estimated_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cacheability": {
          "enum": [
            "provider_prefix_candidate",
            "task_selective",
            "task_fallback",
            "runtime_selection",
            "volatile_suffix"
          ]
        },
        "reload_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "trust": { "$ref": "#/$defs/contextTrust" },
        "issue": { "type": ["string", "null"] }
      }
    },
    "promptBundleDiff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_path",
        "status",
        "baseline_request_shape_hash",
        "current_request_shape_hash",
        "request_shape_changed",
        "baseline_bundle_hash",
        "current_bundle_hash",
        "bundle_changed",
        "first_difference",
        "stable_diff",
        "changed_blocks",
        "issues"
      ],
      "properties": {
        "baseline_path": { "type": "string" },
        "status": {
          "enum": [
            "unchanged",
            "changed",
            "baseline_missing",
            "baseline_unreadable",
            "baseline_invalid",
            "baseline_without_prompt_bundle"
          ]
        },
        "baseline_request_shape_hash": { "type": ["string", "null"] },
        "current_request_shape_hash": { "type": "string" },
        "request_shape_changed": { "type": ["boolean", "null"] },
        "baseline_bundle_hash": { "type": ["string", "null"] },
        "current_bundle_hash": { "type": "string" },
        "bundle_changed": { "type": ["boolean", "null"] },
        "first_difference": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/promptBundleBlockDiff" }
          ]
        },
        "stable_diff": { "$ref": "#/$defs/promptBundleStableDiff" },
        "changed_blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/promptBundleBlockDiff" }
        },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "promptBundleStableDiff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_block_count",
        "baseline_stable_block_count",
        "matching_prefix_blocks",
        "matching_prefix_ratio",
        "stable_prefix_preserved",
        "first_stable_difference",
        "first_stable_invalidation_reason"
      ],
      "properties": {
        "stable_block_count": { "type": "integer", "minimum": 0 },
        "baseline_stable_block_count": { "type": ["integer", "null"], "minimum": 0 },
        "matching_prefix_blocks": { "type": "integer", "minimum": 0 },
        "matching_prefix_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "stable_prefix_preserved": { "type": ["boolean", "null"] },
        "first_stable_difference": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/promptBundleBlockDiff" }
          ]
        },
        "first_stable_invalidation_reason": { "type": ["string", "null"] }
      }
    },
    "promptBundleBlockDiff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "cache_layer",
        "order",
        "current_id",
        "baseline_id",
        "reason",
        "fields"
      ],
      "properties": {
        "kind": { "enum": ["added", "removed", "changed"] },
        "cache_layer": { "type": ["string", "null"], "enum": ["stable", "task", "volatile", null] },
        "order": { "type": ["integer", "null"], "minimum": 1 },
        "current_id": { "type": ["string", "null"] },
        "baseline_id": { "type": ["string", "null"] },
        "reason": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
