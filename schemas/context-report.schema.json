{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/context-report.schema.json",
  "title": "mustflow context report",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/agentContextReport" },
    { "$ref": "#/$defs/promptCacheProfileReport" }
  ],
  "$defs": {
    "agentContextReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "command",
        "mustflow_root",
        "installed",
        "manifest_lock",
        "template",
        "authority",
        "capabilities",
        "read_order",
        "optional_read_order",
        "command_contract",
        "effective_policy",
        "state_policy",
        "blocked_actions",
        "latest_run",
        "issues"
      ],
      "properties": {
        "schema_version": { "const": "1" },
        "command": { "const": "context" },
        "mustflow_root": { "type": "string" },
        "installed": { "type": "boolean" },
        "manifest_lock": { "enum": ["missing", "invalid", "present"] },
        "template": { "$ref": "#/$defs/templateContext" },
        "authority": { "$ref": "#/$defs/scalarObject" },
        "capabilities": { "$ref": "#/$defs/scalarObject" },
        "read_order": {
          "type": "array",
          "items": { "$ref": "#/$defs/pathContext" }
        },
        "optional_read_order": {
          "type": "array",
          "items": { "$ref": "#/$defs/pathContext" }
        },
        "command_contract": { "$ref": "#/$defs/commandContractContext" },
        "technology_preferences": { "$ref": "#/$defs/technologyPreferencesContext" },
        "effective_policy": { "$ref": "#/$defs/effectivePolicy" },
        "state_policy": { "$ref": "#/$defs/statePolicy" },
        "blocked_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "latest_run": { "$ref": "#/$defs/latestRun" },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "promptCacheProfileReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "command",
        "cache_profile",
        "prompt_cache",
        "issues"
      ],
      "properties": {
        "schema_version": { "const": "1" },
        "command": { "const": "context" },
        "cache_profile": { "enum": ["stable", "task", "volatile", "all"] },
        "prompt_cache": { "$ref": "#/$defs/promptCacheSettings" },
        "stable_prefix": { "$ref": "#/$defs/stablePrefixLayer" },
        "task_context": { "$ref": "#/$defs/taskContextLayer" },
        "volatile_suffix": { "$ref": "#/$defs/volatileSuffixLayer" },
        "cache_audit": { "$ref": "#/$defs/promptCacheAudit" },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "templateContext": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "version"],
          "properties": {
            "id": { "type": "string" },
            "version": { "type": "string" }
          }
        }
      ]
    },
    "scalar": { "type": ["string", "number", "boolean", "null"] },
    "scalarObject": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          { "$ref": "#/$defs/scalar" },
          {
            "type": "array",
            "items": { "$ref": "#/$defs/scalar" }
          }
        ]
      }
    },
    "pathContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists"],
      "properties": {
        "path": { "type": "string" },
        "exists": { "type": "boolean" }
      }
    },
    "intentContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "lifecycle", "run_policy", "description"],
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "lifecycle": { "type": ["string", "null"] },
        "run_policy": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] }
      }
    },
    "commandContractContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists", "intents", "runnable_intents"],
      "properties": {
        "path": { "type": "string" },
        "exists": { "type": "boolean" },
        "intents": {
          "type": "array",
          "items": { "$ref": "#/$defs/intentContext" }
        },
        "runnable_intents": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "technologyPreference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "name",
        "status",
        "authority",
        "scope",
        "ecosystem",
        "packages",
        "rationale",
        "constraints"
      ],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["language", "runtime", "framework", "library", "tool", "service", "platform"] },
        "name": { "type": "string" },
        "status": { "enum": ["preferred", "allowed", "avoid"] },
        "authority": { "const": "hint" },
        "scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ecosystem": { "type": ["string", "null"] },
        "packages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rationale": { "type": ["string", "null"] },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "technologyPreferencesContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists", "authority", "guidance", "count", "preferences", "issues"],
      "properties": {
        "path": { "type": "string" },
        "exists": { "type": "boolean" },
        "authority": { "const": "hint" },
        "guidance": {
          "type": "array",
          "items": { "type": "string" }
        },
        "count": { "type": "integer", "minimum": 0 },
        "preferences": {
          "type": "array",
          "items": { "$ref": "#/$defs/technologyPreference" }
        },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "effectivePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entrypoint",
        "nearest_agents",
        "command_contract",
        "project_commands_require_mf_run",
        "allow_inferred_commands",
        "auto_stage",
        "auto_commit",
        "auto_push",
        "state_is_versioned",
        "raw_logs_allowed"
      ],
      "properties": {
        "entrypoint": { "type": "string" },
        "nearest_agents": { "type": "string" },
        "command_contract": { "type": "string" },
        "project_commands_require_mf_run": { "type": "boolean" },
        "allow_inferred_commands": { "type": "boolean" },
        "auto_stage": { "type": "boolean" },
        "auto_commit": { "type": "boolean" },
        "auto_push": { "type": "boolean" },
        "state_is_versioned": { "type": "boolean" },
        "raw_logs_allowed": { "type": "boolean" }
      }
    },
    "statePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cache_path",
        "state_path",
        "versioned",
        "safe_to_delete",
        "stores_raw_conversation",
        "stores_full_terminal_output",
        "stores_hidden_chain_of_thought"
      ],
      "properties": {
        "cache_path": { "type": "string" },
        "state_path": { "type": "string" },
        "versioned": { "type": "boolean" },
        "safe_to_delete": { "type": "boolean" },
        "stores_raw_conversation": { "type": "boolean" },
        "stores_full_terminal_output": { "type": "boolean" },
        "stores_hidden_chain_of_thought": { "type": "boolean" }
      }
    },
    "latestRun": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "exists"],
          "properties": {
            "path": { "type": "string" },
            "exists": { "const": false }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "exists", "valid", "error"],
          "properties": {
            "path": { "type": "string" },
            "exists": { "const": true },
            "valid": { "const": false },
            "error": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "exists",
            "valid",
            "intent",
            "status",
            "timed_out",
            "exit_code",
            "finished_at",
            "duration_ms"
          ],
          "properties": {
            "path": { "type": "string" },
            "exists": { "const": true },
            "valid": { "const": true },
            "intent": { "type": "string" },
            "status": { "type": "string" },
            "timed_out": { "type": "boolean" },
            "exit_code": { "type": ["integer", "null"] },
            "finished_at": { "type": ["string", "null"] },
            "duration_ms": { "type": ["integer", "null"] }
          }
        }
      ]
    },
    "promptCacheSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "strategy",
        "stable_prefix_policy",
        "prefer_references_when_unchanged",
        "exclude_volatile_state_from_prefix",
        "include_content_hashes",
        "max_stable_prefix_kb",
        "max_task_context_kb",
        "max_volatile_suffix_kb"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "strategy": { "type": ["string", "null"] },
        "stable_prefix_policy": { "type": ["string", "null"] },
        "prefer_references_when_unchanged": { "type": "boolean" },
        "exclude_volatile_state_from_prefix": { "type": "boolean" },
        "include_content_hashes": { "type": "boolean" },
        "max_stable_prefix_kb": { "type": ["integer", "null"] },
        "max_task_context_kb": { "type": ["integer", "null"] },
        "max_volatile_suffix_kb": { "type": ["integer", "null"] }
      }
    },
    "stablePrefixLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cache_layer", "cache_key", "policy", "documents", "volatile_excluded"],
      "properties": {
        "cache_layer": { "const": "stable" },
        "cache_key": { "type": ["string", "null"] },
        "policy": { "type": ["string", "null"] },
        "documents": {
          "type": "array",
          "items": { "$ref": "#/$defs/promptCacheDocument" }
        },
        "volatile_excluded": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "promptCacheDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists", "content_hash"],
      "properties": {
        "path": { "type": "string" },
        "exists": { "type": "boolean" },
        "content_hash": { "type": ["string", "null"] }
      }
    },
    "taskContextLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cache_layer", "read_policy", "sources", "local_index"],
      "properties": {
        "cache_layer": { "const": "task" },
        "read_policy": { "type": ["string", "null"] },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "local_index": { "$ref": "#/$defs/promptCacheLocalIndex" }
      }
    },
    "promptCacheLocalIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "status",
        "database_path",
        "index_fresh",
        "stale_paths",
        "search_backend",
        "search_fts5_available",
        "refresh_hint"
      ],
      "properties": {
        "source": { "const": "local_index" },
        "status": { "enum": ["fresh", "missing", "stale", "unreadable"] },
        "database_path": { "type": "string" },
        "index_fresh": { "type": "boolean" },
        "stale_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "search_backend": { "type": ["string", "null"], "enum": ["fts5", "table_scan", null] },
        "search_fts5_available": { "type": ["boolean", "null"] },
        "refresh_hint": { "type": ["string", "null"] }
      }
    },
    "volatileSuffixLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cache_layer",
        "sources",
        "never_place_before_stable_prefix",
        "include_absolute_root",
        "include_latest_run"
      ],
      "properties": {
        "cache_layer": { "const": "volatile" },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "never_place_before_stable_prefix": { "type": "boolean" },
        "include_absolute_root": { "const": false },
        "include_latest_run": { "const": false }
      }
    },
    "promptCacheAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["measurement", "estimator", "canonicalization", "layers", "issues"],
      "properties": {
        "measurement": { "const": "reference_bundle" },
        "estimator": { "$ref": "#/$defs/promptCacheAuditEstimator" },
        "canonicalization": {
          "type": "array",
          "items": { "type": "string" }
        },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/promptCacheAuditLayer" }
        },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "promptCacheAuditEstimator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "estimated_bytes_per_token", "caveat"],
      "properties": {
        "name": { "const": "reference_bundle_utf8_lf_v1" },
        "estimated_bytes_per_token": { "const": 4 },
        "caveat": { "type": "string" }
      }
    },
    "promptCacheAuditLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cache_layer",
        "budget_kb",
        "budget_bytes",
        "rendered_bytes",
        "estimated_tokens",
        "budget_status",
        "blocks",
        "largest_blocks",
        "issues"
      ],
      "properties": {
        "cache_layer": { "enum": ["stable", "task", "volatile"] },
        "budget_kb": { "type": ["integer", "null"] },
        "budget_bytes": { "type": ["integer", "null"] },
        "rendered_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "estimated_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "budget_status": { "enum": ["within_budget", "over_budget", "unknown"] },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/promptCacheAuditBlock" }
        },
        "largest_blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/promptCacheAuditBlock" }
        },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "promptCacheAuditBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "path",
        "source",
        "exists",
        "content_hash",
        "rendered_bytes",
        "estimated_tokens",
        "budget_share",
        "issue"
      ],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["file", "source_placeholder"] },
        "path": { "type": ["string", "null"] },
        "source": { "type": ["string", "null"] },
        "exists": { "type": ["boolean", "null"] },
        "content_hash": { "type": ["string", "null"] },
        "rendered_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "estimated_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "budget_share": { "type": ["number", "null"], "minimum": 0 },
        "issue": { "type": ["string", "null"] }
      }
    }
  }
}
