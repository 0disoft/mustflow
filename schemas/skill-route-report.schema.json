{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/skill-route-report.schema.json",
  "title": "mustflow skill route report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "input",
    "signals",
    "selected",
    "candidates",
    "source_files",
    "gap_notes",
    "command",
    "action"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "kind": { "const": "skill_route_resolution" },
    "command": { "const": "skill" },
    "action": { "const": "route" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_text_present", "paths", "reasons", "max_candidates"],
      "properties": {
        "task_text_present": { "type": "boolean" },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "max_candidates": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_terms", "path_terms", "reasons", "read_shards"],
      "properties": {
        "task_terms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "path_terms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "read_shards": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "selected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["main", "adjuncts"],
      "properties": {
        "main": {
          "oneOf": [
            { "$ref": "#/$defs/candidate" },
            { "type": "null" }
          ]
        },
        "adjuncts": {
          "type": "array",
          "items": { "$ref": "#/$defs/candidate" }
        }
      }
    },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidate" }
    },
    "read_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_limits",
        "stable_kernel",
        "selected_skill_paths",
        "candidate_skill_paths",
        "fallback_route_metadata",
        "expanded_index",
        "avoid_by_default",
        "notes"
      ],
      "properties": {
        "selection_limits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["candidates", "main", "adjuncts"],
          "properties": {
            "candidates": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10
            },
            "main": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1
            },
            "adjuncts": {
              "type": "integer",
              "minimum": 0,
              "maximum": 2
            }
          }
        },
        "stable_kernel": {
          "type": "array",
          "items": { "type": "string" }
        },
        "selected_skill_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "candidate_skill_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fallback_route_metadata": { "$ref": "#/$defs/readPlanFile" },
        "expanded_index": { "$ref": "#/$defs/readPlanFile" },
        "avoid_by_default": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "source_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gap_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "script_pack_suggestions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "input", "analyzed_paths", "suggestions", "issues"],
      "properties": {
        "status": { "type": "string", "enum": ["suggested", "empty", "partial"] },
        "input": { "$ref": "#/$defs/scriptPackSuggestionInput" },
        "analyzed_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackAnalyzedPath" }
        },
        "suggestions": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackSuggestion" }
        },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "scriptPackPhase": {
      "type": "string",
      "enum": ["before_change", "during_change", "after_change", "review"]
    },
    "scriptPackSurface": {
      "type": "string",
      "enum": [
        "config",
        "docs",
        "generated",
        "package",
        "schema",
        "skill",
        "source",
        "template",
        "test",
        "unknown"
      ]
    },
    "scriptPackSuggestionInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phases", "skills", "paths", "changed"],
      "properties": {
        "phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackPhase" }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
        },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "changed": { "type": "boolean" }
      }
    },
    "scriptPackAnalyzedPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "surfaces"],
      "properties": {
        "path": { "type": "string" },
        "surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackSurface" },
          "minItems": 1
        }
      }
    },
    "scriptPackSuggestion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_ref",
        "score",
        "confidence",
        "usage",
        "phases",
        "matched_phases",
        "matched_skills",
        "matched_surfaces",
        "reasons",
        "read_only",
        "mutates",
        "network",
        "risk_level",
        "cost",
        "report_schema_file",
        "run_hint"
      ],
      "properties": {
        "script_ref": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "score": { "type": "integer", "minimum": 0 },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "usage": { "type": "string" },
        "phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackPhase" },
          "minItems": 1
        },
        "matched_phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackPhase" }
        },
        "matched_skills": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
        },
        "matched_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackSurface" }
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "read_only": { "type": "boolean" },
        "mutates": { "type": "boolean" },
        "network": { "type": "boolean" },
        "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
        "cost": { "type": "string", "enum": ["low", "medium", "high"] },
        "report_schema_file": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-z0-9-]+\\.schema\\.json$" },
            { "type": "null" }
          ]
        },
        "safety_contract": {
          "$ref": "#/$defs/safetyContract"
        },
        "run_hint": { "type": "string" }
      }
    },
    "safetyContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_class",
        "execution_mode",
        "command_authority",
        "run_hint_authority",
        "input_scope",
        "output_scope",
        "cannot_satisfy_intents",
        "forbidden_actions"
      ],
      "properties": {
        "authority_class": { "const": "advisory_evidence" },
        "execution_mode": { "const": "suggestion_only" },
        "command_authority": { "const": "requires_configured_intent" },
        "run_hint_authority": { "const": "not_authority" },
        "input_scope": { "const": "explicit_or_changed_paths" },
        "output_scope": { "const": "bounded_report" },
        "cannot_satisfy_intents": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "forbidden_actions": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skill",
        "skill_path",
        "trigger",
        "category",
        "route_type",
        "priority",
        "applies_to_reasons",
        "score",
        "score_breakdown",
        "selection_reasons",
        "verification_intents"
      ],
      "properties": {
        "skill": { "type": "string" },
        "skill_path": { "type": "string" },
        "trigger": { "type": "string" },
        "category": {
          "type": ["string", "null"],
          "enum": [
            "bug_failure",
            "general_code",
            "tests",
            "docs_release",
            "security_privacy",
            "data_external",
            "ui_assets",
            "architecture_patterns",
            "workflow_contracts",
            null
          ]
        },
        "route_type": { "type": "string" },
        "priority": { "type": "integer" },
        "applies_to_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "score": { "type": "number" },
        "score_breakdown": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reason_match",
            "task_text_match",
            "path_match",
            "route_type_weight",
            "priority_weight"
          ],
          "properties": {
            "reason_match": { "type": "number" },
            "task_text_match": { "type": "number" },
            "path_match": { "type": "number" },
            "pattern_signal_match": { "type": "number" },
            "negative_signal_penalty": { "type": "number" },
            "route_type_weight": { "type": "number" },
            "priority_weight": { "type": "number" }
          }
        },
        "selection_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "matched_dimensions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "reason",
              "task_terms",
              "path_terms",
              "path_skill_hint",
              "pattern_signal",
              "negative_signal",
              "route_type",
              "priority"
            ]
          }
        },
        "route_card": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "index_read_policy",
            "compact_fields",
            "matched_dimensions",
            "route_dependencies",
            "use_when_excerpt",
            "do_not_use_excerpt",
            "read_strategy"
          ],
          "properties": {
            "source": { "const": "route_metadata_and_skill_frontmatter" },
            "index_read_policy": { "const": "fallback_only" },
            "compact_fields": {
              "type": "array",
              "items": { "type": "string" }
            },
            "matched_dimensions": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "reason",
                  "task_terms",
                  "path_terms",
                  "path_skill_hint",
                  "pattern_signal",
                  "negative_signal",
                  "route_type",
                  "priority"
                ]
              }
            },
            "route_dependencies": { "$ref": "#/$defs/routeDependencies" },
            "use_when_excerpt": { "$ref": "#/$defs/routeExcerptReference" },
            "do_not_use_excerpt": { "$ref": "#/$defs/routeExcerptReference" },
            "read_strategy": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          }
        },
        "verification_intents": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "routeDependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requires_skills", "suggests_adjuncts", "conflicts_with", "unlocks_on"],
      "properties": {
        "requires_skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suggests_adjuncts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conflicts_with": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unlocks_on": {
          "type": "array",
          "items": { "$ref": "#/$defs/routeUnlockRule" }
        }
      }
    },
    "routeUnlockRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal", "skill"],
      "properties": {
        "signal": { "type": "string" },
        "skill": { "type": "string" }
      }
    },
    "routeExcerptReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_path", "section", "read_when"],
      "properties": {
        "source_path": { "type": "string" },
        "section": { "type": "string", "enum": ["use-when", "do-not-use-when"] },
        "read_when": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "readPlanFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "read_when"],
      "properties": {
        "path": { "type": "string" },
        "read_when": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
