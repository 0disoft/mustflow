{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/commands.schema.json",
  "title": "mustflow command contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "defaults", "intents"],
  "properties": {
    "schema_version": { "const": "1" },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_behavior",
        "allow_inferred_commands",
        "require_lifecycle",
        "require_timeout_for_oneshot",
        "deny_unmanaged_long_running",
        "default_cwd",
        "default_timeout_seconds",
        "stdin",
        "max_output_bytes",
        "on_timeout",
        "kill_after_seconds"
      ],
      "properties": {
        "missing_behavior": { "type": "string" },
        "allow_inferred_commands": { "type": "boolean" },
        "require_lifecycle": { "type": "boolean" },
        "require_timeout_for_oneshot": { "type": "boolean" },
        "deny_unmanaged_long_running": { "type": "boolean" },
        "default_cwd": { "type": "string" },
        "default_timeout_seconds": { "type": "integer" },
        "stdin": { "enum": ["closed"] },
        "max_output_bytes": { "type": "integer" },
        "on_timeout": { "type": "string" },
        "kill_after_seconds": { "type": "integer" },
        "env_policy": { "$ref": "#/$defs/envPolicy" },
        "env_allowlist": { "$ref": "#/$defs/stringArray" },
        "allow_project_local_bin_bare_executables": { "$ref": "#/$defs/stringArray" }
      }
    },
    "intents": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/intent" }
    },
    "resources": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/resource" }
    },
    "include": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files"],
      "properties": {
        "files": {
          "type": "array",
          "items": { "type": "string", "pattern": "^commands/(?:[A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+\\.toml$" },
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "envPolicy": {
      "enum": ["inherit", "minimal", "allowlist"]
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["path", "cache", "database", "service", "port", "gpu", "resource"] },
        "paths": { "$ref": "#/$defs/stringArray" },
        "concurrency": { "enum": ["shared_reader", "exclusive_writer", "exclusive"] },
        "description": { "type": "string" }
      }
    },
    "effect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["read", "write"] },
        "mode": { "enum": ["read", "write", "append", "replace", "delete_recreate"] },
        "path": { "type": "string" },
        "paths": { "$ref": "#/$defs/stringArray" },
        "lock": { "type": "string" },
        "concurrency": { "enum": ["shared", "exclusive"] }
      }
    },
    "coverageHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reasons": { "$ref": "#/$defs/stringArray" },
        "surfaces": { "$ref": "#/$defs/stringArray" },
        "paths": { "$ref": "#/$defs/stringArray" },
        "contracts": { "$ref": "#/$defs/stringArray" }
      }
    },
    "selectionHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coverage_level": { "type": "string" },
        "coverage_confidence": { "type": "string" },
        "accepts_changed_files": { "type": "string" },
        "accepts_test_targets": { "type": "boolean" },
        "fallback_intents": { "$ref": "#/$defs/stringArray" },
        "escalate_to": { "$ref": "#/$defs/stringArray" }
      }
    },
    "intentInputs": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z][a-z0-9_]*$" },
      "additionalProperties": { "$ref": "#/$defs/intentInput" }
    },
    "intentInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["path", "enum", "boolean", "integer", "literal"] },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "placeholder": { "type": "string" },
        "secret": { "type": "boolean" },
        "allowed_roots": { "$ref": "#/$defs/stringArray" },
        "allowed_extensions": { "$ref": "#/$defs/stringArray" },
        "allowed_values": { "$ref": "#/$defs/stringArray" },
        "value": { "type": ["string", "number", "boolean"] },
        "min": { "type": "integer" },
        "max": { "type": "integer" }
      }
    },
    "costHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expected_seconds": { "type": "integer", "minimum": 0 },
        "cold_start_seconds": { "type": "integer", "minimum": 0 },
        "timeout_ratio_expectation": { "type": "number", "minimum": 0 },
        "cost_tier": { "type": "string" }
      }
    },
    "intentPrecondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["path_exists", "artifact_freshness"] },
        "label": { "type": "string" },
        "path": { "type": "string" },
        "artifact": { "type": "string" },
        "sources": { "$ref": "#/$defs/stringArray" },
        "satisfy_intent": { "type": "string" }
      }
    },
    "relationHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subsumes": { "$ref": "#/$defs/stringArray" },
        "subsumed_by": { "$ref": "#/$defs/stringArray" },
        "requires_with": { "$ref": "#/$defs/stringArray" },
        "escalate_to": { "$ref": "#/$defs/stringArray" }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "description"],
      "properties": {
        "status": { "enum": ["configured", "manual_only", "unknown"] },
        "kind": { "type": "string" },
        "lifecycle": { "type": "string" },
        "run_policy": { "type": "string" },
        "description": { "type": "string" },
        "argv": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cmd": { "type": "string" },
        "allow_shell": { "type": "boolean" },
        "allow_long_running_command_patterns": { "type": "boolean" },
        "cwd": { "type": "string" },
        "timeout_seconds": { "type": "integer" },
        "kill_after_seconds": { "type": "integer" },
        "stdin": { "type": "string" },
        "success_exit_codes": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "writes": {
          "$ref": "#/$defs/stringArray"
        },
        "env_policy": { "$ref": "#/$defs/envPolicy" },
        "env_allowlist": { "$ref": "#/$defs/stringArray" },
        "allow_env_inheritance_risks": { "type": "boolean" },
        "manual_start_hint": { "type": "string" },
        "health_check_url": { "type": "string" },
        "stop_instruction": { "type": "string" },
        "related_oneshot_checks": { "$ref": "#/$defs/stringArray" },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/effect" }
        },
        "network": { "type": "boolean" },
        "destructive": { "type": "boolean" },
        "approval_actions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "git_commit",
              "git_push",
              "dependency_install",
              "dependency_upgrade",
              "network_access",
              "database_migration",
              "destructive_command",
              "secret_access",
              "release",
              "cross_repository_change"
            ]
          }
        },
        "required_after": {
          "type": "array",
          "items": { "type": "string" }
        },
        "covers": { "$ref": "#/$defs/coverageHints" },
        "selection": { "$ref": "#/$defs/selectionHints" },
        "inputs": { "$ref": "#/$defs/intentInputs" },
        "preconditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/intentPrecondition" }
        },
        "cost": { "$ref": "#/$defs/costHints" },
        "relations": { "$ref": "#/$defs/relationHints" },
        "reason": { "type": "string" },
        "agent_action": { "type": "string" }
      }
    }
  }
}
