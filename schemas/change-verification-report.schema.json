{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.dev/schemas/change-verification-report.schema.json",
  "title": "mustflow change verification report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source",
    "files",
    "classification_summary",
    "requirements",
    "candidates",
    "gaps",
    "schedule",
    "decision_graph",
    "test_selection"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "source": {
      "enum": ["changed", "paths"]
    },
    "files": {
      "$ref": "#/$defs/stringArray"
    },
    "classification_summary": {
      "$ref": "#/$defs/classificationSummary"
    },
    "verification_plan_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verificationRequirement"
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verificationCandidate"
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verificationGap"
      }
    },
    "schedule": {
      "$ref": "#/$defs/verificationSchedule"
    },
    "decision_graph": {
      "$ref": "#/$defs/verificationDecisionGraph"
    },
    "test_selection": {
      "$ref": "#/$defs/testSelectionReport"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updatePolicy": {
      "enum": ["update", "update_or_mark_stale", "not_applicable"]
    },
    "classificationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fileCount",
        "publicSurfaceCount",
        "changeKinds",
        "validationReasons",
        "updatePolicies",
        "driftChecks",
        "affectedContracts"
      ],
      "properties": {
        "fileCount": {
          "type": "integer"
        },
        "publicSurfaceCount": {
          "type": "integer"
        },
        "changeKinds": {
          "$ref": "#/$defs/stringArray"
        },
        "validationReasons": {
          "$ref": "#/$defs/stringArray"
        },
        "updatePolicies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/updatePolicy"
          }
        },
        "driftChecks": {
          "$ref": "#/$defs/stringArray"
        },
        "affectedContracts": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "verificationRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "files",
        "surfaces",
        "affectedContracts",
        "driftChecks",
        "updatePolicies",
        "source"
      ],
      "properties": {
        "reason": {
          "type": "string"
        },
        "files": {
          "$ref": "#/$defs/stringArray"
        },
        "surfaces": {
          "$ref": "#/$defs/stringArray"
        },
        "affectedContracts": {
          "$ref": "#/$defs/stringArray"
        },
        "driftChecks": {
          "$ref": "#/$defs/stringArray"
        },
        "updatePolicies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/updatePolicy"
          }
        },
        "source": {
          "const": "change_classification"
        },
        "surfaceReadModels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localPathSurfaceReadModel"
          }
        }
      }
    },
    "localPathSurfaceReadModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "status",
        "databasePath",
        "indexFresh",
        "stalePaths",
        "inputPath",
        "match",
        "refreshHint"
      ],
      "properties": {
        "source": { "const": "local_index" },
        "status": { "enum": ["fresh", "missing", "stale", "unreadable"] },
        "databasePath": { "type": "string" },
        "indexFresh": { "type": "boolean" },
        "stalePaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inputPath": { "type": ["string", "null"] },
        "match": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/localPathSurfaceRuleMatch" }
          ]
        },
        "refreshHint": { "type": ["string", "null"] }
      }
    },
    "localPathSurfaceRuleMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleId",
        "patternKind",
        "pattern",
        "patternFlags",
        "changeKinds",
        "surface"
      ],
      "properties": {
        "ruleId": { "type": "string" },
        "patternKind": { "type": "string" },
        "pattern": { "type": "string" },
        "patternFlags": { "type": "string" },
        "changeKinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "surface": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "category",
            "isPublicSurface",
            "validationReasons",
            "affectedContracts",
            "updatePolicy",
            "driftChecks"
          ],
          "properties": {
            "kind": { "type": "string" },
            "category": { "type": "string" },
            "isPublicSurface": { "type": "boolean" },
            "validationReasons": {
              "type": "array",
              "items": { "type": "string" }
            },
            "affectedContracts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "updatePolicy": { "enum": ["update", "update_or_mark_stale", "not_applicable"] },
            "driftChecks": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "skipReason": {
      "enum": [
        "no_matching_intents",
        "intent_not_table",
        "status_not_configured",
        "lifecycle_not_oneshot",
        "run_policy_not_agent_allowed",
        "stdin_not_closed",
        "missing_timeout",
        "missing_command_source",
        "unsafe_intent_name",
        "blocked_shell_background_pattern"
      ]
    },
    "verificationCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "intent",
        "status",
        "skipReason",
        "detail",
        "candidateState",
        "eligibilityState",
        "selectionState"
      ],
      "properties": {
        "reason": {
          "type": "string"
        },
        "intent": {
          "type": ["string", "null"]
        },
        "status": {
          "enum": ["runnable", "skipped"]
        },
        "skipReason": {
          "anyOf": [
            {
              "$ref": "#/$defs/skipReason"
            },
            {
              "type": "null"
            }
          ]
        },
        "detail": {
          "type": ["string", "null"]
        },
        "candidateState": {
          "enum": ["candidate", "gap"]
        },
        "eligibilityState": {
          "enum": ["eligible", "ineligible", "missing"]
        },
        "selectionState": {
          "enum": ["selected", "not_selected", "not_applicable"]
        }
      }
    },
    "verificationGap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "files", "surfaces", "detail"],
      "properties": {
        "reason": {
          "type": "string"
        },
        "files": {
          "$ref": "#/$defs/stringArray"
        },
        "surfaces": {
          "$ref": "#/$defs/stringArray"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "testSelectionReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "status",
        "configPath",
        "authority",
        "commandAuthority",
        "grantsCommandAuthority",
        "matches",
        "selected",
        "notes"
      ],
      "properties": {
        "source": {
          "const": "test-selection.toml"
        },
        "status": {
          "enum": ["missing", "matched", "unmatched", "invalid"]
        },
        "configPath": {
          "const": ".mustflow/config/test-selection.toml"
        },
        "authority": {
          "const": ".mustflow/config/test-selection.toml"
        },
        "commandAuthority": {
          "const": ".mustflow/config/commands.toml"
        },
        "grantsCommandAuthority": {
          "const": false
        },
        "matches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/testSelectionRuleMatch"
          }
        },
        "selected": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/testSelectionCandidate"
          }
        },
        "notes": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "testSelectionRuleMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleId",
        "risk",
        "reason",
        "files",
        "surfaces",
        "intent",
        "fallbackIntent",
        "testTargets"
      ],
      "properties": {
        "ruleId": { "type": "string" },
        "risk": { "type": "string" },
        "reason": { "type": "string" },
        "files": { "$ref": "#/$defs/stringArray" },
        "surfaces": { "$ref": "#/$defs/stringArray" },
        "intent": { "type": "string" },
        "fallbackIntent": { "type": "string" },
        "testTargets": { "$ref": "#/$defs/stringArray" }
      }
    },
    "testSelectionCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleId",
        "reason",
        "intent",
        "role",
        "status",
        "skipReason",
        "detail",
        "testTargets",
        "appliedTestTargets",
        "testTargetsApplied"
      ],
      "properties": {
        "ruleId": { "type": "string" },
        "reason": { "type": "string" },
        "intent": { "type": "string" },
        "role": { "enum": ["primary", "fallback"] },
        "status": { "enum": ["runnable", "skipped"] },
        "skipReason": {
          "anyOf": [
            { "$ref": "#/$defs/skipReason" },
            { "type": "null" }
          ]
        },
        "detail": { "type": ["string", "null"] },
        "testTargets": { "$ref": "#/$defs/stringArray" },
        "appliedTestTargets": { "$ref": "#/$defs/stringArray" },
        "testTargetsApplied": { "type": "boolean" }
      }
    },
    "verificationScheduleEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "source", "access", "mode", "path", "lock", "concurrency"],
      "properties": {
        "intent": {
          "type": "string"
        },
        "source": {
          "enum": ["effects", "writes"]
        },
        "access": {
          "enum": ["read", "write"]
        },
        "mode": {
          "enum": ["read", "write", "append", "replace", "delete_recreate"]
        },
        "path": {
          "type": ["string", "null"]
        },
        "lock": {
          "type": "string"
        },
        "concurrency": {
          "enum": ["shared", "exclusive"]
        }
      }
    },
    "verificationScheduleConflict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "conflictsWith", "lock", "detail"],
      "properties": {
        "intent": {
          "type": "string"
        },
        "conflictsWith": {
          "type": "string"
        },
        "lock": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "verificationScheduleEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "status", "parallelEligible", "parallelReason", "effects", "locks", "conflicts"],
      "properties": {
        "intent": {
          "type": "string"
        },
        "status": {
          "const": "runnable"
        },
        "parallelEligible": {
          "type": "boolean"
        },
        "parallelReason": {
          "enum": ["explicit_effects", "missing_explicit_effects", "undeclared_write_drift"]
        },
        "effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationScheduleEffect"
          }
        },
        "locks": {
          "$ref": "#/$defs/stringArray"
        },
        "conflicts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationScheduleConflict"
          }
        },
        "effectGraph": {
          "$ref": "#/$defs/commandEffectGraph"
        }
      }
    },
    "commandEffectGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "authority",
        "commandAuthority",
        "grantsCommandAuthority",
        "status",
        "databasePath",
        "indexFresh",
        "stalePaths",
        "writeLocks",
        "lockConflicts",
        "refreshHint"
      ],
      "properties": {
        "source": { "const": "local_index" },
        "authority": { "const": "explanation_only" },
        "commandAuthority": { "const": ".mustflow/config/commands.toml" },
        "grantsCommandAuthority": { "const": false },
        "status": { "enum": ["fresh", "missing", "stale", "unreadable"] },
        "databasePath": { "type": "string" },
        "indexFresh": { "type": "boolean" },
        "stalePaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "writeLocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/commandWriteLock" }
        },
        "lockConflicts": {
          "type": "array",
          "items": { "$ref": "#/$defs/commandLockConflict" }
        },
        "refreshHint": { "type": ["string", "null"] }
      }
    },
    "commandWriteLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lock", "paths", "modes", "sources", "concurrencies", "effectCount"],
      "properties": {
        "lock": { "type": "string" },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "modes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concurrencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "effectCount": { "type": "integer" }
      }
    },
    "commandLockConflict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent",
        "lock",
        "paths",
        "modes",
        "concurrencies",
        "conflictingPaths",
        "conflictingModes",
        "conflictingConcurrencies"
      ],
      "properties": {
        "intent": { "type": "string" },
        "lock": { "type": "string" },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "modes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concurrencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conflictingPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conflictingModes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conflictingConcurrencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "verificationScheduleBatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "intents", "locks"],
      "properties": {
        "index": {
          "type": "integer"
        },
        "intents": {
          "$ref": "#/$defs/stringArray"
        },
        "locks": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "verificationSchedule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runner", "failurePolicy", "batches", "entries", "notes"],
      "properties": {
        "runner": {
          "const": "serial_mf_run_receipts"
        },
        "failurePolicy": {
          "$ref": "#/$defs/verificationScheduleFailurePolicy"
        },
        "batches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationScheduleBatch"
          }
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationScheduleEntry"
          }
        },
        "notes": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "verificationScheduleFailurePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "startedBatch", "nextBatch"],
      "properties": {
        "mode": {
          "const": "batch_boundary"
        },
        "startedBatch": {
          "const": "wait_for_completion"
        },
        "nextBatch": {
          "const": "stop_on_failure"
        }
      }
    },
    "verificationDecisionGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "root", "summary", "nodes", "edges"],
      "properties": {
        "schema_version": {
          "const": "1"
        },
        "root": {
          "const": "verification_decision"
        },
        "summary": {
          "$ref": "#/$defs/verificationDecisionGraphSummary"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationDecisionGraphNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationDecisionGraphEdge"
          }
        }
      }
    },
    "verificationDecisionGraphSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodeCount",
        "edgeCount",
        "runnable",
        "skipped",
        "blocked",
        "manual_only",
        "unknown",
        "gapCount"
      ],
      "properties": {
        "nodeCount": {
          "type": "integer"
        },
        "edgeCount": {
          "type": "integer"
        },
        "runnable": {
          "type": "integer"
        },
        "skipped": {
          "type": "integer"
        },
        "blocked": {
          "type": "integer"
        },
        "manual_only": {
          "type": "integer"
        },
        "unknown": {
          "type": "integer"
        },
        "selected": {
          "type": "integer"
        },
        "not_selected": {
          "type": "integer"
        },
        "gapCount": {
          "type": "integer"
        }
      }
    },
    "verificationDecisionGraphNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "label", "status", "reason", "intent", "data"],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "changed_surface",
            "classification_reason",
            "command_candidate",
            "eligibility",
            "effect",
            "gap",
            "receipt"
          ]
        },
        "label": {
          "type": "string"
        },
        "status": {
          "type": ["string", "null"],
          "enum": ["runnable", "skipped", "blocked", "manual_only", "unknown", "not_applicable", null]
        },
        "reason": {
          "type": ["string", "null"]
        },
        "intent": {
          "type": ["string", "null"]
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "verificationDecisionGraphEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "kind"],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "kind": {
          "enum": ["supports", "requires", "evaluates", "has_effect", "has_gap"]
        }
      }
    }
  }
}
