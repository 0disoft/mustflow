{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.dev/schemas/change-verification-report.schema.json",
  "title": "mustflow change verification report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source",
    "files",
    "classification_summary",
    "requirements",
    "candidates",
    "gaps",
    "schedule"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "source": {
      "enum": ["changed", "paths"]
    },
    "files": {
      "$ref": "#/$defs/stringArray"
    },
    "classification_summary": {
      "$ref": "#/$defs/classificationSummary"
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verificationRequirement"
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verificationCandidate"
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verificationGap"
      }
    },
    "schedule": {
      "$ref": "#/$defs/verificationSchedule"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updatePolicy": {
      "enum": ["update", "update_or_mark_stale", "not_applicable"]
    },
    "classificationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fileCount",
        "publicSurfaceCount",
        "changeKinds",
        "validationReasons",
        "updatePolicies",
        "driftChecks",
        "affectedContracts"
      ],
      "properties": {
        "fileCount": {
          "type": "integer"
        },
        "publicSurfaceCount": {
          "type": "integer"
        },
        "changeKinds": {
          "$ref": "#/$defs/stringArray"
        },
        "validationReasons": {
          "$ref": "#/$defs/stringArray"
        },
        "updatePolicies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/updatePolicy"
          }
        },
        "driftChecks": {
          "$ref": "#/$defs/stringArray"
        },
        "affectedContracts": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "verificationRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "files",
        "surfaces",
        "affectedContracts",
        "driftChecks",
        "updatePolicies",
        "source"
      ],
      "properties": {
        "reason": {
          "type": "string"
        },
        "files": {
          "$ref": "#/$defs/stringArray"
        },
        "surfaces": {
          "$ref": "#/$defs/stringArray"
        },
        "affectedContracts": {
          "$ref": "#/$defs/stringArray"
        },
        "driftChecks": {
          "$ref": "#/$defs/stringArray"
        },
        "updatePolicies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/updatePolicy"
          }
        },
        "source": {
          "const": "change_classification"
        }
      }
    },
    "skipReason": {
      "enum": [
        "no_matching_intents",
        "intent_not_table",
        "status_not_configured",
        "lifecycle_not_oneshot",
        "run_policy_not_agent_allowed",
        "stdin_not_closed",
        "missing_timeout",
        "missing_command_source",
        "unsafe_intent_name",
        "blocked_shell_background_pattern"
      ]
    },
    "verificationCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "intent", "status", "skipReason", "detail"],
      "properties": {
        "reason": {
          "type": "string"
        },
        "intent": {
          "type": ["string", "null"]
        },
        "status": {
          "enum": ["runnable", "skipped"]
        },
        "skipReason": {
          "anyOf": [
            {
              "$ref": "#/$defs/skipReason"
            },
            {
              "type": "null"
            }
          ]
        },
        "detail": {
          "type": ["string", "null"]
        }
      }
    },
    "verificationGap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "files", "surfaces", "detail"],
      "properties": {
        "reason": {
          "type": "string"
        },
        "files": {
          "$ref": "#/$defs/stringArray"
        },
        "surfaces": {
          "$ref": "#/$defs/stringArray"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "verificationScheduleEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "source", "access", "mode", "path", "lock", "concurrency"],
      "properties": {
        "intent": {
          "type": "string"
        },
        "source": {
          "enum": ["effects", "writes"]
        },
        "access": {
          "enum": ["read", "write"]
        },
        "mode": {
          "enum": ["read", "write", "append", "replace", "delete_recreate"]
        },
        "path": {
          "type": "string"
        },
        "lock": {
          "type": "string"
        },
        "concurrency": {
          "enum": ["shared", "exclusive"]
        }
      }
    },
    "verificationScheduleConflict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "conflictsWith", "lock", "detail"],
      "properties": {
        "intent": {
          "type": "string"
        },
        "conflictsWith": {
          "type": "string"
        },
        "lock": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "verificationScheduleEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "status", "effects", "locks", "conflicts"],
      "properties": {
        "intent": {
          "type": "string"
        },
        "status": {
          "const": "runnable"
        },
        "effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationScheduleEffect"
          }
        },
        "locks": {
          "$ref": "#/$defs/stringArray"
        },
        "conflicts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationScheduleConflict"
          }
        }
      }
    },
    "verificationScheduleBatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "intents", "locks"],
      "properties": {
        "index": {
          "type": "integer"
        },
        "intents": {
          "$ref": "#/$defs/stringArray"
        },
        "locks": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "verificationSchedule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runner", "batches", "entries", "notes"],
      "properties": {
        "runner": {
          "const": "serial_mf_run_receipts"
        },
        "batches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationScheduleBatch"
          }
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationScheduleEntry"
          }
        },
        "notes": {
          "$ref": "#/$defs/stringArray"
        }
      }
    }
  }
}
