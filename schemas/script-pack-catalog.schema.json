{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/script-pack-catalog.schema.json",
  "title": "mustflow script-pack catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "action",
    "ok",
    "mustflow_root",
    "packs",
    "issues"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "command": { "const": "script-pack" },
    "action": { "const": "list" },
    "ok": { "type": "boolean" },
    "mustflow_root": { "type": "string" },
    "packs": {
      "type": "array",
      "items": { "$ref": "#/$defs/pack" }
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary_key", "scripts"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "summary_key": { "type": "string" },
        "scripts": {
          "type": "array",
          "items": { "$ref": "#/$defs/script" }
        }
      }
    },
    "script": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ref", "usage", "summary_key", "actions", "report_schema_file"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "ref": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "usage": { "type": "string" },
        "summary_key": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "minItems": 1
        },
        "use_when": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "phases": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["before_change", "during_change", "after_change", "review"]
          },
          "minItems": 1
        },
        "read_only": { "type": "boolean" },
        "mutates": { "type": "boolean" },
        "network": { "type": "boolean" },
        "inputs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$" },
          "minItems": 1
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$" },
          "minItems": 1
        },
        "related_skills": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
        },
        "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
        "cost": { "type": "string", "enum": ["low", "medium", "high"] },
        "report_schema_file": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-z0-9-]+\\.schema\\.json$" },
            { "type": "null" }
          ]
        },
        "safety_contract": {
          "$ref": "#/$defs/safetyContract"
        }
      }
    },
    "safetyContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_class",
        "execution_mode",
        "command_authority",
        "run_hint_authority",
        "input_scope",
        "output_scope",
        "cannot_satisfy_intents",
        "forbidden_actions"
      ],
      "properties": {
        "authority_class": { "const": "advisory_evidence" },
        "execution_mode": { "const": "suggestion_only" },
        "command_authority": { "const": "requires_configured_intent" },
        "run_hint_authority": { "const": "not_authority" },
        "input_scope": { "const": "explicit_or_changed_paths" },
        "output_scope": { "const": "bounded_report" },
        "cannot_satisfy_intents": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "forbidden_actions": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    }
  }
}
