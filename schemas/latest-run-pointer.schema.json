{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/latest-run-pointer.schema.json",
  "title": "mustflow latest run pointer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "kind",
    "reason",
    "reasons",
    "plan_source",
    "verification_plan_id",
    "status",
    "summary",
    "run_dir",
    "manifest_path"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "command": { "const": "verify" },
    "kind": { "const": "verify_run_summary" },
    "reason": { "type": "string" },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "plan_source": { "type": ["string", "null"] },
    "verification_plan_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "status": { "enum": ["passed", "partial", "failed", "blocked"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matched", "ran", "passed", "failed", "skipped"],
      "properties": {
        "matched": { "type": "integer" },
        "ran": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" }
      }
    },
    "run_dir": { "type": "string" },
    "manifest_path": { "type": "string" }
  }
}
