{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/code-outline-report.schema.json",
  "title": "mustflow code-outline report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "pack_id",
    "script_id",
    "script_ref",
    "action",
    "status",
    "ok",
    "mustflow_root",
    "policy",
    "input_hash",
    "files",
    "anchors",
    "symbols",
    "findings",
    "issues"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "command": { "const": "script-pack" },
    "pack_id": { "const": "code" },
    "script_id": { "const": "outline" },
    "script_ref": { "const": "code/outline" },
    "action": { "const": "scan" },
    "status": { "enum": ["passed", "failed", "error"] },
    "ok": { "type": "boolean" },
    "mustflow_root": { "type": "string" },
    "policy": { "$ref": "#/$defs/policy" },
    "input_hash": { "$ref": "#/$defs/sha256" },
    "files": {
      "type": "array",
      "items": { "$ref": "#/$defs/file" }
    },
    "anchors": {
      "type": "array",
      "items": { "$ref": "#/$defs/anchor" }
    },
    "symbols": {
      "type": "array",
      "items": { "$ref": "#/$defs/symbol" }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "language": {
      "enum": ["typescript", "tsx", "javascript", "jsx", "javascript-module", "javascript-commonjs", "astro", "svelte", "go", "rust", "python"]
    },
    "symbolKind": {
      "enum": ["function", "class", "interface", "type", "enum", "variable"]
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_file_bytes", "max_files", "extensions", "ignored_directories"],
      "properties": {
        "max_file_bytes": { "type": "integer", "minimum": 1 },
        "max_files": { "type": "integer", "minimum": 1 },
        "extensions": { "$ref": "#/$defs/stringArray" },
        "ignored_directories": { "$ref": "#/$defs/stringArray" }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "language", "sha256", "size_bytes", "line_count", "symbol_count"],
      "properties": {
        "kind": { "const": "source_file" },
        "path": { "type": "string" },
        "language": { "$ref": "#/$defs/language" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "line_count": { "type": "integer", "minimum": 0 },
        "symbol_count": { "type": "integer", "minimum": 0 }
      }
    },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "line_start",
        "line_end",
        "purpose",
        "search",
        "invariant",
        "risk",
        "navigation_only",
        "can_instruct_agent",
        "target_symbol_id",
        "target_kind",
        "target_name",
        "target_start_line"
      ],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "purpose": { "type": ["string", "null"] },
        "search": { "$ref": "#/$defs/stringArray" },
        "invariant": { "type": ["string", "null"] },
        "risk": { "$ref": "#/$defs/stringArray" },
        "navigation_only": { "const": true },
        "can_instruct_agent": { "const": false },
        "target_symbol_id": { "type": ["string", "null"] },
        "target_kind": {
          "anyOf": [
            { "$ref": "#/$defs/symbolKind" },
            { "type": "null" }
          ]
        },
        "target_name": { "type": ["string", "null"] },
        "target_start_line": { "type": ["integer", "null"], "minimum": 1 }
      }
    },
    "symbol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "language",
        "kind",
        "name",
        "start_line",
        "end_line",
        "signature",
        "exported",
        "async",
        "return_type",
        "return_behavior",
        "return_count",
        "return_lines",
        "return_preview",
        "parent",
        "content_sha256"
      ],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" },
        "language": { "$ref": "#/$defs/language" },
        "kind": { "$ref": "#/$defs/symbolKind" },
        "name": { "type": "string" },
        "start_line": { "type": "integer", "minimum": 1 },
        "end_line": { "type": "integer", "minimum": 1 },
        "signature": { "type": "string" },
        "exported": { "type": "boolean" },
        "async": { "type": "boolean" },
        "return_type": { "type": ["string", "null"] },
        "return_behavior": {
          "enum": ["value", "void", "implicit_undefined", "mixed", "throws_only", "unknown"]
        },
        "return_count": { "type": "integer", "minimum": 0 },
        "return_lines": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        },
        "return_preview": { "type": ["string", "null"] },
        "parent": { "type": ["string", "null"] },
        "content_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message", "path"],
      "properties": {
        "code": {
          "enum": [
            "code_outline_path_outside_root",
            "code_outline_unreadable_path",
            "code_outline_unsupported_file",
            "code_outline_file_too_large",
            "code_outline_max_files_exceeded"
          ]
        },
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "message": { "type": "string" },
        "path": { "type": "string" }
      }
    }
  }
}
