{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/next-report.schema.json",
  "title": "mustflow next report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "mustflow_root",
    "status",
    "policy",
    "state",
    "decision",
    "recommended_commands",
    "blockers",
    "warnings",
    "gaps",
    "verification_plan_id"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "command": { "const": "next" },
    "mustflow_root": { "type": "string" },
    "status": {
      "enum": ["setup_required", "blocked", "idle", "needs_verification", "unavailable"]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_authority",
        "direct_commands_allowed",
        "grants_command_authority",
        "writes_files"
      ],
      "properties": {
        "command_authority": { "const": ".mustflow/config/commands.toml" },
        "direct_commands_allowed": { "const": false },
        "grants_command_authority": { "const": false },
        "writes_files": { "const": false }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "installed",
        "check_ok",
        "command_contract_ok",
        "git_status",
        "changed_file_count",
        "validation_reasons",
        "selected_intents",
        "gap_count"
      ],
      "properties": {
        "installed": { "type": "boolean" },
        "check_ok": { "type": "boolean" },
        "command_contract_ok": { "type": "boolean" },
        "git_status": { "enum": ["available", "unavailable"] },
        "changed_file_count": { "type": ["integer", "null"] },
        "validation_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "selected_intents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "gap_count": { "type": "integer" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "command", "title", "detail"],
      "properties": {
        "kind": {
          "enum": ["setup", "repair", "inspect", "configure_commands", "verify", "none"]
        },
        "command": { "type": ["string", "null"] },
        "title": { "type": "string" },
        "detail": { "type": "string" }
      }
    },
    "recommended_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reason", "files", "surfaces", "detail"],
        "properties": {
          "reason": { "type": "string" },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "surfaces": {
            "type": "array",
            "items": { "type": "string" }
          },
          "detail": { "type": "string" }
        }
      }
    },
    "script_pack_suggestions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "input", "analyzed_paths", "suggestions", "issues"],
      "properties": {
        "status": { "type": "string", "enum": ["suggested", "empty", "partial"] },
        "input": { "$ref": "#/$defs/scriptPackSuggestionInput" },
        "analyzed_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackAnalyzedPath" }
        },
        "suggestions": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackSuggestion" }
        },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "verification_plan_id": { "type": ["string", "null"] }
  },
  "$defs": {
    "scriptPackPhase": {
      "type": "string",
      "enum": ["before_change", "during_change", "after_change", "review"]
    },
    "scriptPackSurface": {
      "type": "string",
      "enum": [
        "config",
        "docs",
        "generated",
        "package",
        "schema",
        "skill",
        "source",
        "template",
        "test",
        "unknown"
      ]
    },
    "scriptPackSuggestionInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phases", "skills", "paths", "changed"],
      "properties": {
        "phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackPhase" }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
        },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "changed": { "type": "boolean" }
      }
    },
    "scriptPackAnalyzedPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "surfaces"],
      "properties": {
        "path": { "type": "string" },
        "surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackSurface" },
          "minItems": 1
        }
      }
    },
    "scriptPackSuggestion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_ref",
        "score",
        "confidence",
        "usage",
        "phases",
        "matched_phases",
        "matched_skills",
        "matched_surfaces",
        "reasons",
        "read_only",
        "mutates",
        "network",
        "risk_level",
        "cost",
        "report_schema_file",
        "run_hint"
      ],
      "properties": {
        "script_ref": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "score": { "type": "integer", "minimum": 0 },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "usage": { "type": "string" },
        "phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackPhase" },
          "minItems": 1
        },
        "matched_phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackPhase" }
        },
        "matched_skills": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
        },
        "matched_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/scriptPackSurface" }
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "read_only": { "type": "boolean" },
        "mutates": { "type": "boolean" },
        "network": { "type": "boolean" },
        "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
        "cost": { "type": "string", "enum": ["low", "medium", "high"] },
        "report_schema_file": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-z0-9-]+\\.schema\\.json$" },
            { "type": "null" }
          ]
        },
        "run_hint": { "type": "string" }
      }
    }
  }
}
