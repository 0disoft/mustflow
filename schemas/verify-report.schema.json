{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mustflow.github.io/schemas/verify-report.schema.json",
  "title": "mustflow verify report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "mustflow_root",
    "reason",
    "reasons",
    "plan_source",
    "status",
    "summary",
    "results"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "command": { "const": "verify" },
    "mustflow_root": { "type": "string" },
    "reason": { "type": "string" },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "plan_source": { "type": ["string", "null"] },
    "status": { "enum": ["passed", "partial", "failed", "blocked"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matched", "ran", "passed", "failed", "skipped"],
      "properties": {
        "matched": { "type": "integer" },
        "ran": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "intent",
          "status",
          "skipped",
          "reason",
          "detail",
          "exit_code",
          "receipt"
        ],
        "properties": {
          "intent": { "type": ["string", "null"] },
          "status": { "enum": ["passed", "failed", "timed_out", "start_failed", "skipped"] },
          "skipped": { "type": "boolean" },
          "reason": { "type": ["string", "null"] },
          "detail": { "type": ["string", "null"] },
          "exit_code": { "type": ["integer", "null"] },
          "receipt": { "type": ["object", "null"] }
        }
      }
    }
  }
}
